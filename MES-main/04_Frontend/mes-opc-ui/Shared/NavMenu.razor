@using Microsoft.AspNetCore.Components.Routing
@using mes_opc_ui.Services
@inject LocalizationService Loc

<div class="sidebar @(_collapsed ? "sidebar--collapsed" : "")">

    @* ── Toggle Button (very top) ── *@
    <div class="sidebar-toggle-row">
        <button class="sidebar-toggle" @onclick="ToggleCollapsed" title="@(_collapsed ? "Développer" : "Réduire")">
            <svg class="toggle-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                @if (_collapsed)
                {
                    @* Arrow right (>) when collapsed *@
                    <polyline points="9 18 15 12 9 6" />
                }
                else
                {
                    @* Arrow left (<) when expanded *@
                    <polyline points="15 18 9 12 15 6" />
                }
            </svg>
        </button>
    </div>

    @* ── Header (brand) ── *@
    <div class="sidebar-header">
        <div class="sidebar-header-content">
            <svg class="brand-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="32" height="32" rx="8" fill="#1e60b2"/>
                <path d="M8 22V14l8-6 8 6v8" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="13" y="18" width="6" height="4" rx="1" stroke="#fff" stroke-width="1.5"/>
            </svg>
            <div class="brand-text">
                <div class="brand-title">MES OPC</div>
                <div class="brand-subtitle">Production Dashboard</div>
            </div>
        </div>
    </div>

    @* ── Nav Links ── *@
    <div class="sidebar-nav">

        <NavLink class="nav-link" href="/admin" Match="NavLinkMatch.All" title="Vue d'ensemble">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("page.dashboard.title")</span>
        </NavLink>

        @* VUE OPÉRATEUR *@
        <div class="nav-section"><span class="nav-section-text">@Loc.T("sidebar.operator_view")</span></div>
        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All" title="Dashboard Realtime">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("sidebar.dashboard_rt")</span>
        </NavLink>

        @* CONFIGURATION *@
        <div class="nav-section"><span class="nav-section-text">@Loc.T("sidebar.configuration")</span></div>
        <NavLink class="nav-link" href="/admin/opc-endpoints" title="OPC Endpoints">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("page.endpoints.title")</span>
        </NavLink>
        <NavLink class="nav-link" href="/admin/machines" title="Machines">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("page.machines.title")</span>
        </NavLink>
        <NavLink class="nav-link" href="/admin/cycle-rules" title="Cycle Rules">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("page.rules.title")</span>
        </NavLink>

        @* ANALYTICS *@
        <div class="nav-section"><span class="nav-section-text">@Loc.T("sidebar.analytics")</span></div>
        <NavLink class="nav-link" href="/admin/analytics" title="KPIs production">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("sidebar.kpis")</span>
        </NavLink>
        <NavLink class="nav-link" href="/admin/analytics-reports" title="Rapports">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("page.reports.title")</span>
        </NavLink>
        <NavLink class="nav-link" href="/admin/ui-dashboards" title="UI Dashboards">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("page.ui.title")</span>
        </NavLink>
    </div>

    @* ── Settings Button (bottom) ── *@
    <div class="sidebar-footer">
        <button class="nav-link settings-btn" @onclick="() => showSettings = true" title="Paramètres">
            <span class="nav-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
            </span>
            <span class="nav-text">@Loc.T("sidebar.settings")</span>
        </button>
    </div>
</div>

<SettingsModal Show="showSettings" OnClose="() => showSettings = false" />

<style>
    /* ────────────────────────────────────────────────
       Base Sidebar
    ──────────────────────────────────────────────── */
    .sidebar {
        width: 260px;
        background-color: #0d2340;
        color: #fff;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        height: 100vh;
        overflow: hidden;
        border-inline-end: 1px solid rgba(255,255,255,0.06);
        position: relative;
        transition: width 0.25s ease;
    }

    .sidebar--collapsed {
        width: 48px;
    }

    /* ────────────────────────────────────────────────
       Toggle Row (TOP)
    ──────────────────────────────────────────────── */
    .sidebar-toggle-row {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 10px 10px 6px 10px;
        flex-shrink: 0;
    }

    .sidebar--collapsed .sidebar-toggle-row {
        justify-content: center;
        padding: 10px 0 6px 0;
    }

    .sidebar-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 6px;
        cursor: pointer;
        color: #94a3b8;
        flex-shrink: 0;
        transition: background 0.2s, color 0.2s;
        padding: 0;
    }

    .sidebar-toggle:hover {
        background: #1e60b2;
        color: #ffffff;
        border-color: #1e60b2;
    }

    .toggle-arrow {
        width: 13px;
        height: 13px;
    }

    /* ────────────────────────────────────────────────
       Header (Brand)
    ──────────────────────────────────────────────── */
    .sidebar-header {
        padding: 6px 12px 14px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
        overflow: hidden;
    }

    .sidebar--collapsed .sidebar-header {
        padding: 6px 0 14px 0;
        display: flex;
        justify-content: center;
    }

    .sidebar-header-content {
        display: flex;
        align-items: center;
        gap: 10px;
        white-space: nowrap;
        overflow: hidden;
    }

    .brand-icon {
        width: 30px;
        height: 30px;
        flex-shrink: 0;
    }

    .brand-text {
        overflow: hidden;
        transition: opacity 0.2s ease, max-width 0.25s ease;
        opacity: 1;
        max-width: 200px;
        white-space: nowrap;
    }

    .sidebar--collapsed .brand-text {
        opacity: 0;
        max-width: 0;
        pointer-events: none;
    }

    .brand-title {
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 0.3px;
        color: #ffffff;
        line-height: 1.2;
    }

    .brand-subtitle {
        font-size: 11px;
        font-weight: 400;
        color: #7896b8;
        margin-top: 1px;
        white-space: nowrap;
    }

    /* ────────────────────────────────────────────────
       Nav
    ──────────────────────────────────────────────── */
    .sidebar-nav {
        display: flex;
        flex-direction: column;
        padding: 8px 6px;
        overflow-y: auto;
        overflow-x: hidden;
        flex: 1;
    }

    /* Section labels */
    .nav-section {
        display: flex;
        align-items: center;
        padding: 0 8px;
        height: 30px;
        margin-top: 14px;
        margin-bottom: 2px;
        overflow: hidden;
    }

    .nav-section-text {
        font-size: 10px;
        font-weight: 700;
        color: #4a6480;
        text-transform: uppercase;
        letter-spacing: 1px;
        white-space: nowrap;
        transition: opacity 0.2s ease, max-width 0.25s ease;
        overflow: hidden;
        opacity: 1;
        max-width: 200px;
    }

    .sidebar--collapsed .nav-section-text {
        opacity: 0;
        max-width: 0;
        pointer-events: none;
    }

    .sidebar--collapsed .nav-section {
        justify-content: center;
        height: 2px;
        margin-top: 8px;
        margin-bottom: 4px;
        padding: 0;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    /* Nav Links */
    .sidebar-nav .nav-link, .sidebar-footer .nav-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 8px;
        text-decoration: none;
        color: #8eaac8;
        font-size: 13.5px;
        font-weight: 500;
        transition: background 0.15s, color 0.15s;
        margin-bottom: 1px;
        white-space: nowrap;
        overflow: hidden;
        border: none;
        background: transparent;
        cursor: pointer;
        width: 100%;
        text-align: start;
    }

    .sidebar-nav .nav-link:hover {
        color: #e2e8f0;
        background-color: rgba(255,255,255,0.07);
        text-decoration: none;
    }

    .sidebar-nav .nav-link.active {
        background-color: #1e60b2;
        color: #ffffff;
        font-weight: 600;
    }

    /* Collapsed: center icons */
    .sidebar--collapsed .sidebar-nav .nav-link {
        justify-content: center;
        padding: 8px 0;
    }

    /* Nav Icon */
    .nav-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .nav-icon svg {
        width: 17px;
        height: 17px;
    }

    /* Nav Label */
    .nav-text {
        flex: 1;
        transition: opacity 0.2s ease, max-width 0.25s ease;
        opacity: 1;
        max-width: 200px;
        overflow: hidden;
    }

    .sidebar--collapsed .nav-text {
        opacity: 0;
        max-width: 0;
        pointer-events: none;
    }

    /* ────────────────────────────────────────────────
       Footer (Settings)
    ──────────────────────────────────────────────── */
    .sidebar-footer {
        padding: 8px 6px 12px 6px;
        border-top: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .sidebar-footer .settings-btn {
        width: 100%;
    }

    .sidebar--collapsed .sidebar-footer {
        padding: 8px 0 12px 0;
    }

    /* ────────────────────────────────────────────────
       Responsive
    ──────────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .sidebar {
            width: 100% !important;
            height: auto;
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }
        .sidebar-toggle-row { display: none; }
        .brand-text { opacity: 1 !important; max-width: 200px !important; }
        .nav-text { opacity: 1 !important; max-width: 200px !important; }
        .nav-section-text { opacity: 1 !important; max-width: 200px !important; }
        .sidebar-nav .nav-link { justify-content: flex-start !important; }
    }
</style>

@code {
    private bool _collapsed;
    private bool showSettings;

    private void ToggleCollapsed()
    {
        _collapsed = !_collapsed;
    }
}
