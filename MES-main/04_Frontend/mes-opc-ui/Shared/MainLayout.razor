@inherits LayoutComponentBase
@using mes_opc_ui.Services
@inject LocalizationService Loc
@implements IDisposable

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .app-shell {
        display: flex;
        flex-direction: row;
        min-height: 100vh;
        background: #f8fafc; /* very light background for content */
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* ── Content ── */
    .content-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
        height: 100vh;
        overflow-y: auto;
        overflow-x: auto; /* prevents table truncation when sidebar collapses */
    }

    .content {
        padding: 32px 40px;
        max-width: 1400px;
        width: 100%;
        margin: 0 auto;
    }

    @@media (max-width: 768px) {
        .app-shell {
            flex-direction: column;
        }
        .content { padding: 20px 16px; }
        .content-wrapper { height: auto; overflow-y: visible; }
    }
</style>

<CascadingValue Value="Loc" Name="Loc">
    <div class="app-shell" @key="Loc.CurrentLang">
        <NavMenu />
        <div class="content-wrapper">
            <main class="content">
                @Body
            </main>
        </div>
    </div>
</CascadingValue>

@code {
    protected override void OnInitialized()
        => Loc.OnLanguageChanged += Refresh;

    public void Dispose()
        => Loc.OnLanguageChanged -= Refresh;

    private void Refresh() => InvokeAsync(StateHasChanged);
}
