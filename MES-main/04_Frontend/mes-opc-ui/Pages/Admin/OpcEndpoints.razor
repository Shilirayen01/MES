@page "/admin/opc-endpoints"
@using Microsoft.AspNetCore.Components.Forms
@using mes_opc_ui.Services.AdminApi
@inject OpcEndpointsApiClient Api

<h3>OPC Endpoints</h3>

<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
    <button class="btn btn-sm btn-primary" @onclick="New">+ Nouveau Endpoint</button>
    <label class="form-check form-check-inline mb-0">
        <input class="form-check-input" type="checkbox" @bind="ShowOnlyActive" />
        <span class="form-check-label">Afficher seulement actifs</span>
    </label>
    <button class="btn btn-sm btn-outline-light" @onclick="Load">Rafraîchir</button>
</div>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger py-2">@Error</div>
}

@if (Items is null)
{
    <div class="alert alert-info py-2">Chargement…</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-striped table-hover align-middle">
            <thead>
            <tr>
                <th style="width:70px;">Id</th>
                <th style="width:260px;">Name</th>
                <th>EndpointUrl</th>
                <th style="width:90px;">Active</th>
                <th style="width:220px;"></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var e in Items)
            {
                <tr>
                    <td>@e.Id</td>
                    <td>@e.Name</td>
                    <td style="word-break:break-all;">@e.EndpointUrl</td>
                    <td>@(e.IsActive ? "Yes" : "No")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-info" @onclick="() => Edit(e)">Edit</button>
                        <button class="btn btn-sm btn-outline-warning ms-2" @onclick="() => Deactivate(e)">Désactiver</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@if (Form is not null)
{
    <hr />
    <h5 class="mt-3">@(IsEdit ? $"Modifier endpoint #{EditId}" : "Créer endpoint")</h5>

    <EditForm Model="Form" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label class="form-label">Name</label>
            <InputText class="form-control" @bind-Value="Form.Name" />
        </div>

        <div class="mb-2">
            <label class="form-label">EndpointUrl</label>
            <InputText class="form-control" @bind-Value="Form.EndpointUrl" />
        </div>

        <div class="mb-2">
            <label class="form-label">Description</label>
            <InputText class="form-control" @bind-Value="Form.Description" />
        </div>

        <div class="form-check mb-3">
            <InputCheckbox class="form-check-input" @bind-Value="Form.IsActive" />
            <label class="form-check-label">Active</label>
        </div>

        <button class="btn btn-primary" type="submit">Enregistrer</button>
        <button class="btn btn-secondary ms-2" type="button" @onclick="Cancel">Annuler</button>
    </EditForm>

}

@code {
    private List<OpcEndpointDto>? Items;
    private string? Error;
    private bool ShowOnlyActive = true;

    private OpcEndpointUpdateDto? Form;
    private int EditId;
    private bool IsEdit;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        Error = null;
        Items = null;
        StateHasChanged();

        try
        {
            Items = await Api.GetAllAsync(ShowOnlyActive ? true : null) ?? [];
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            Items = [];
        }
    }

    private void New()
    {
        IsEdit = false;
        EditId = 0;
        Form = new OpcEndpointUpdateDto { IsActive = true };
    }

    private void Edit(OpcEndpointDto e)
    {
        IsEdit = true;
        EditId = e.Id;
        Form = new OpcEndpointUpdateDto
        {
            Name = e.Name,
            EndpointUrl = e.EndpointUrl,
            Description = e.Description,
            IsActive = e.IsActive
        };
    }

    private async Task Deactivate(OpcEndpointDto e)
    {
        try
        {
            await Api.DeleteAsync(e.Id); // soft delete (IsActive=false)
            await Load();
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task Save()
    {
        if (Form is null) return;

        try
        {
            if (!IsEdit)
            {
                await Api.CreateAsync(new OpcEndpointCreateDto
                {
                    Name = Form.Name,
                    EndpointUrl = Form.EndpointUrl,
                    Description = Form.Description,
                    IsActive = Form.IsActive,
                    CreatedBy = "admin-ui"
                });
            }
            else
            {
                await Api.UpdateAsync(EditId, Form);
            }

            Form = null;
            await Load();
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private void Cancel() => Form = null;
}
