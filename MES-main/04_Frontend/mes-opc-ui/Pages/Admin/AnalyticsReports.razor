@page "/admin/analytics-reports"
@using mes_opc_ui.Services.AdminApi
@inject AnalyticsResultsApiClient ReportsApi
@inject MachinesApiClient MachinesApi

<h3>Rapports Analytics — Résultats de Production</h3>
<p class="text-muted small mb-3">Consultez les KPIs et résumés calculés après chaque cycle de production.</p>

@* ── Filters ────────────────────────────────────────────────────────────────── *@
<div class="d-flex flex-wrap align-items-end gap-3 mb-3">
    <div>
        <label class="form-label small mb-1">Machine</label>
        <select class="form-select form-select-sm" style="min-width:200px" @bind="_machine">
            <option value="">-- Sélectionner --</option>
            @foreach (var m in _machines)
            {
                <option value="@m.MachineCode">@m.MachineCode — @m.Name</option>
            }
        </select>
    </div>
    <div>
        <label class="form-label small mb-1">Depuis</label>
        <input class="form-control form-control-sm" type="datetime-local" @bind="_from" />
    </div>
    <div>
        <label class="form-label small mb-1">Jusqu'à</label>
        <input class="form-control form-control-sm" type="datetime-local" @bind="_to" />
    </div>
    <div>
        <label class="form-label small mb-1">Limite</label>
        <input class="form-control form-control-sm" type="number" style="width:80px" @bind="_limit" />
    </div>
    <button class="btn btn-sm btn-primary" @onclick="Search">Rechercher</button>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@* ── Results ────────────────────────────────────────────────────────────────── *@
@if (_runs is not null)
{
    @if (_runs.Count == 0)
    {
        <div class="alert alert-info">Aucun run trouvé pour cette période.</div>
    }
    else
    {
        <p class="text-muted small">@_runs.Count run(s) trouvé(s)</p>

        @foreach (var run in _runs)
        {
            <div class="card bg-dark border-secondary mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>
                        <strong>@run.ScopeKey</strong>
                        <span class="badge @StatusBadge(run.Status) ms-2">@run.Status</span>
                        <small class="text-muted ms-2">@run.StartTs.ToString("dd/MM HH:mm:ss")</small>
                        @if (run.EndTs.HasValue)
                        {
                            <small class="text-muted"> → @run.EndTs.Value.ToString("HH:mm:ss")</small>
                        }
                        @if (run.DurationSeconds.HasValue)
                        {
                            <span class="badge bg-dark ms-2">@FormatDuration(run.DurationSeconds.Value)</span>
                        }
                    </span>
                    <small class="text-muted font-monospace">@run.RunId.ToString()[..8]</small>
                </div>
                <div class="card-body p-2">
                    @if (run.SummaryValues.Count > 0 || run.KpiValues.Count > 0)
                    {
                        <table class="table table-dark table-sm mb-0">
                            <thead>
                                <tr><th>Indicateur</th><th>Valeur</th><th>Unité</th><th>Type</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var s in run.SummaryValues)
                                {
                                    <tr>
                                        <td><code>@s.FieldName</code></td>
                                        <td class="fw-bold">@(s.Value.HasValue ? s.Value.Value.ToString("N2") : "—")</td>
                                        <td>@s.Unit</td>
                                        <td><span class="badge bg-info">Summary</span></td>
                                    </tr>
                                }
                                @foreach (var k in run.KpiValues)
                                {
                                    <tr>
                                        <td><code>@k.KpiCode</code></td>
                                        <td class="fw-bold">@(k.Value.HasValue ? k.Value.Value.ToString("N2") : "—")</td>
                                        <td>@k.Unit</td>
                                        <td><span class="badge bg-warning text-dark">KPI</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">Aucun résultat calculé pour ce run.</p>
                    }
                </div>
            </div>
        }
    }
}

@code {
    private List<ProductionRunResultDto>? _runs;
    private List<MachineDto> _machines = new();
    private string _machine = "";
    private DateTime _from = DateTime.Now.AddDays(-7);
    private DateTime _to = DateTime.Now;
    private int _limit = 50;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try { _machines = await MachinesApi.GetAllAsync(true) ?? []; }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task Search()
    {
        if (string.IsNullOrEmpty(_machine)) { _error = "Sélectionnez une machine."; return; }
        _error = null;
        _runs = null;
        StateHasChanged();

        try
        {
            _runs = await ReportsApi.GetResultsAsync(_machine, _from, _to, _limit) ?? [];
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string StatusBadge(string status) => status?.ToLower() switch
    {
        "completed" => "bg-success",
        "aborted" => "bg-danger",
        "timeout" => "bg-warning text-dark",
        "running" => "bg-primary",
        _ => "bg-secondary"
    };

    private static string FormatDuration(int totalSeconds)
    {
        var ts = TimeSpan.FromSeconds(totalSeconds);
        return ts.Hours > 0 ? $"{ts.Hours}h{ts.Minutes:D2}m{ts.Seconds:D2}s"
            : ts.Minutes > 0 ? $"{ts.Minutes}m{ts.Seconds:D2}s"
            : $"{ts.Seconds}s";
    }
}
