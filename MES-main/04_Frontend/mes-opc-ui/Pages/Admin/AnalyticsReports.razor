@page "/admin/analytics-reports"
@using mes_opc_ui.Services.AdminApi
@inject AnalyticsResultsApiClient ReportsApi
@inject MachinesApiClient MachinesApi

<style>
    .rp-page {
        --white:        #ffffff;
        --bg-soft:      #f8fafc;
        --border:       #e8edf5;
        --border-soft:  #f1f5f9;
        --accent:       #1e40af;
        --accent-dim:   rgba(30,64,175,0.07);
        --green-bg:     #d1fae5;
        --green-txt:    #065f46;
        --green-bdr:    #a7f3d0;
        --red:          #dc2626;
        --red-bg:       rgba(220,38,38,0.07);
        --red-bdr:      #fecaca;
        --orange:       #d97706;
        --orange-bg:    #fffbeb;
        --orange-bdr:   #fde68a;
        --orange-txt:   #92400e;
        --tag-bg:       #dbeafe;
        --tag-txt:      #1e40af;
        --tag-bdr:      #bfdbfe;
        --text-900:     #0f172a;
        --text-navy:    #1e4d7b;
        --text-muted:   #64748b;
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text-900);
    }

    /* ── Header ── */
    .rp-page .page-header {
        display: flex; align-items: flex-end; justify-content: space-between;
        margin-bottom: 28px; padding-bottom: 18px;
        border-bottom: 1px solid var(--border);
    }
    .rp-page .page-header h3 {
        font-size: 24px; font-weight: 800; letter-spacing: -0.5px;
        color: var(--text-900); margin: 0 0 5px 0;
    }
    .rp-page .page-header p {
        font-size: 13px; color: var(--text-navy); margin: 0;
    }

    /* ── Filter Bar ── */
    .rp-page .filter-bar {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px 20px;
        display: flex;
        align-items: flex-end;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 24px;
        box-shadow: 0 1px 4px rgba(15,23,42,0.05);
    }
    .rp-page .filter-group {
        display: flex; flex-direction: column; gap: 5px;
    }
    .rp-page .filter-group label {
        font-size: 11px; color: var(--text-navy);
        font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .rp-page .rp-select,
    .rp-page .rp-input {
        background: var(--bg-soft); border: 1.5px solid var(--border);
        color: var(--text-900); border-radius: 8px; padding: 8px 12px;
        font-size: 13px; font-family: inherit; transition: border-color 0.15s;
    }
    .rp-page .rp-select { min-width: 200px; }
    .rp-page .rp-input-date { min-width: 170px; }
    .rp-page .rp-input-num { width: 80px; }
    .rp-page .rp-select:focus,
    .rp-page .rp-input:focus {
        outline: none; border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-dim);
    }

    /* ── Buttons ── */
    .rp-page .rp-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 20px; border-radius: 8px; font-size: 13px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; border: 1px solid transparent;
        font-family: inherit; line-height: 1.4;
    }
    .rp-page .rp-btn-primary {
        background: var(--accent); color: #fff; border-color: var(--accent);
    }
    .rp-page .rp-btn-primary:hover {
        background: #1e3a8a; box-shadow: 0 4px 14px rgba(30,64,175,0.25); transform: translateY(-1px);
    }

    /* ── Alerts ── */
    .rp-page .rp-alert-danger {
        background: var(--red-bg); border: 1px solid var(--red-bdr);
        color: var(--red); border-radius: 10px; padding: 12px 16px;
        font-size: 13px; margin-bottom: 16px;
    }
    .rp-page .rp-alert-info {
        background: var(--accent-dim); border: 1px solid var(--tag-bdr);
        color: var(--accent); border-radius: 10px; padding: 12px 16px;
        font-size: 13px; margin-bottom: 16px;
    }
    .rp-page .results-count {
        font-size: 13px; color: var(--text-navy);
        margin-bottom: 14px; display: flex; align-items: center; gap: 8px;
    }
    .rp-page .results-count strong {
        font-family: 'JetBrains Mono', monospace;
        color: var(--accent); font-size: 15px; font-weight: 700;
    }

    /* ── Run Card ── */
    .rp-page .run-card {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 14px; overflow: hidden; margin-bottom: 14px;
        transition: box-shadow 0.2s, transform 0.2s;
        animation: rpFadeUp 0.35s ease both;
        box-shadow: 0 1px 4px rgba(15,23,42,0.05);
    }
    .rp-page .run-card:hover {
        box-shadow: 0 4px 18px rgba(15,23,42,0.09);
        transform: translateY(-1px);
    }
    @@keyframes rpFadeUp {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Run Card Header ── */
    .rp-page .run-card-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 13px 18px; border-bottom: 1px solid var(--border-soft);
        background: var(--bg-soft); flex-wrap: wrap; gap: 10px;
    }
    .rp-page .run-card-left {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    }
    .rp-page .run-scope {
        font-family: 'JetBrains Mono', monospace; font-size: 13px;
        font-weight: 700; color: var(--accent);
    }
    .rp-page .run-time {
        font-size: 12px; color: var(--text-navy);
        font-family: 'JetBrains Mono', monospace;
    }
    .rp-page .run-arrow { color: var(--text-muted); font-size: 11px; }
    .rp-page .run-duration {
        display: inline-flex; align-items: center; padding: 2px 9px;
        border-radius: 6px; background: var(--bg-soft); border: 1px solid var(--border);
        color: var(--text-navy); font-family: 'JetBrains Mono', monospace;
        font-size: 11px; font-weight: 600;
    }
    .rp-page .run-id {
        font-family: 'JetBrains Mono', monospace; font-size: 10px;
        color: var(--text-muted); letter-spacing: 0.5px;
    }

    /* ── Status Badges ── */
    .rp-page .status-badge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 10px; border-radius: 6px;
        font-size: 10px; font-weight: 700;
        letter-spacing: 0.4px; text-transform: uppercase;
    }
    .rp-page .status-completed {
        background: var(--green-bg); border: 1px solid var(--green-bdr); color: var(--green-txt);
    }
    .rp-page .status-aborted {
        background: var(--red-bg); border: 1px solid var(--red-bdr); color: var(--red);
    }
    .rp-page .status-timeout {
        background: var(--orange-bg); border: 1px solid var(--orange-bdr); color: var(--orange-txt);
    }
    .rp-page .status-running {
        background: var(--accent-dim); border: 1px solid var(--tag-bdr); color: var(--accent);
    }
    .rp-page .status-default {
        background: var(--bg-soft); border: 1px solid var(--border); color: var(--text-muted);
    }
    .rp-page .status-completed::before,
    .rp-page .status-running::before {
        content: ''; width: 5px; height: 5px; border-radius: 50%;
        background: currentColor; animation: rpPulse 2s ease infinite;
    }
    @@keyframes rpPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

    /* ── Run Card Body ── */
    .rp-page .run-card-body { padding: 14px 18px; }
    .rp-page .no-results-row {
        font-size: 12px; color: var(--text-muted); font-style: italic; padding: 6px 0;
    }

    /* ── Values Table ── */
    .rp-page .values-table {
        width: 100%; border-collapse: collapse; font-size: 12px; table-layout: fixed;
    }
    .rp-page .values-table th:nth-child(1) { width: 35%; }
    .rp-page .values-table th:nth-child(2) { width: 25%; text-align: right; }
    .rp-page .values-table th:nth-child(3) { width: 15%; }
    .rp-page .values-table th:nth-child(4) { width: 25%; }
    .rp-page .values-table th {
        text-align: left; padding: 7px 10px; color: var(--text-navy);
        font-weight: 600; font-size: 10px; text-transform: uppercase;
        letter-spacing: 0.5px; border-bottom: 1px solid var(--border);
        background: var(--bg-soft);
    }
    .rp-page .values-table td {
        padding: 9px 10px; color: var(--text-900);
        border-bottom: 1px solid var(--border-soft); vertical-align: middle;
    }
    .rp-page .values-table tbody tr:last-child td { border-bottom: none; }
    .rp-page .values-table tbody tr:hover td { background: #eff6ff; }
    .rp-page .values-table code {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        color: var(--tag-txt); background: var(--tag-bg); padding: 2px 6px;
        border-radius: 4px; border: 1px solid var(--tag-bdr);
    }
    .rp-page .val-number {
        font-family: 'JetBrains Mono', monospace; font-size: 13px;
        font-weight: 700; color: var(--text-900);
        text-align: right; display: block;
    }
    .rp-page .val-unit { font-size: 11px; color: var(--text-navy); }

    /* ── Type badges ── */
    .rp-page .type-badge-summary {
        display: inline-flex; padding: 2px 8px; border-radius: 5px;
        font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px;
        background: var(--tag-bg); border: 1px solid var(--tag-bdr); color: var(--tag-txt);
    }
    .rp-page .type-badge-kpi {
        display: inline-flex; padding: 2px 8px; border-radius: 5px;
        font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px;
        background: var(--orange-bg); border: 1px solid var(--orange-bdr); color: var(--orange-txt);
    }
</style>

<div class="rp-page">

    @* ── Page Header ── *@
    <div class="page-header">
        <div>
            <h3>Rapports Analytics — Résultats de Production</h3>
            <p>Consultez les KPIs et résumés calculés après chaque cycle de production.</p>
        </div>
    </div>

    @* ── Filter Bar ── *@
    <div class="filter-bar">
        <div class="filter-group">
            <label>Machine</label>
            <select class="rp-select" @bind="_machine">
                <option value="">-- Sélectionner --</option>
                @foreach (var m in _machines)
                {
                    <option value="@m.MachineCode">@m.MachineCode — @m.Name</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <label>Depuis</label>
            <input class="rp-input rp-input-date" type="datetime-local" @bind="_from" />
        </div>
        <div class="filter-group">
            <label>Jusqu'à</label>
            <input class="rp-input rp-input-date" type="datetime-local" @bind="_to" />
        </div>
        <div class="filter-group">
            <label>Limite</label>
            <input class="rp-input rp-input-num" type="number" @bind="_limit" />
        </div>
        <button class="rp-btn rp-btn-primary" @onclick="Search">
            Rechercher
        </button>
    </div>

    @if (_error is not null)
    {
        <div class="rp-alert-danger">@_error</div>
    }

    @* ── Results ── *@
    @if (_runs is not null)
    {
        @if (_runs.Count == 0)
        {
            <div class="rp-alert-info">Aucun run trouvé pour cette période.</div>
        }
        else
        {
            <div class="results-count">
                <strong>@_runs.Count</strong> run@(_runs.Count > 1 ? "s" : "") trouvé@(_runs.Count > 1 ? "s" : "")
            </div>

            @foreach (var run in _runs)
            {
                <div class="run-card">

                    <div class="run-card-header">
                        <div class="run-card-left">
                            <span class="@GetStatusClass(run.Status) status-badge">@run.Status</span>
                            <span class="run-scope">@run.ScopeKey</span>
                            <span class="run-time">@run.StartTs.ToString("dd/MM HH:mm:ss")</span>
                            @if (run.EndTs.HasValue)
                            {
                                <span class="run-arrow">→</span>
                                <span class="run-time">@run.EndTs.Value.ToString("HH:mm:ss")</span>
                            }
                            @if (run.DurationSeconds.HasValue)
                            {
                                <span class="run-duration">@FormatDuration(run.DurationSeconds.Value)</span>
                            }
                        </div>
                        <span class="run-id">@run.RunId.ToString()[..8]</span>
                    </div>

                    <div class="run-card-body">
                        @if (run.SummaryValues.Count > 0 || run.KpiValues.Count > 0)
                        {
                            <table class="values-table">
                                <thead>
                                    <tr>
                                        <th>Indicateur</th>
                                        <th>Valeur</th>
                                        <th>Unité</th>
                                        <th>Type</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in run.SummaryValues)
                                    {
                                        <tr>
                                            <td><code>@s.FieldName</code></td>
                                            <td><span class="val-number">@(s.Value.HasValue ? s.Value.Value.ToString("N2") : "—")</span></td>
                                            <td><span class="val-unit">@s.Unit</span></td>
                                            <td><span class="type-badge-summary">Summary</span></td>
                                        </tr>
                                    }
                                    @foreach (var k in run.KpiValues)
                                    {
                                        <tr>
                                            <td><code>@k.KpiCode</code></td>
                                            <td><span class="val-number">@(k.Value.HasValue ? k.Value.Value.ToString("N2") : "—")</span></td>
                                            <td><span class="val-unit">@k.Unit</span></td>
                                            <td><span class="type-badge-kpi">KPI</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="no-results-row">Aucun résultat calculé pour ce run.</p>
                        }
                    </div>

                </div>
            }
        }
    }

</div>

@code {
    private List<ProductionRunResultDto>? _runs;
    private List<MachineDto> _machines = new();
    private string _machine = "";
    private DateTime _from = DateTime.Now.AddDays(-7);
    private DateTime _to = DateTime.Now;
    private int _limit = 50;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try { _machines = await MachinesApi.GetAllAsync(true) ?? []; }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task Search()
    {
        if (string.IsNullOrEmpty(_machine)) { _error = "Sélectionnez une machine."; return; }
        _error = null;
        _runs = null;
        StateHasChanged();

        try
        {
            _runs = await ReportsApi.GetResultsAsync(_machine, _from, _to, _limit) ?? [];
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string GetStatusClass(string status) => status?.ToLower() switch
    {
        "completed" => "status-completed",
        "aborted"   => "status-aborted",
        "timeout"   => "status-timeout",
        "running"   => "status-running",
        _           => "status-default"
    };

    private static string FormatDuration(int totalSeconds)
    {
        var ts = TimeSpan.FromSeconds(totalSeconds);
        return ts.Hours > 0
            ? $"{ts.Hours}h{ts.Minutes:D2}m{ts.Seconds:D2}s"
            : ts.Minutes > 0
                ? $"{ts.Minutes}m{ts.Seconds:D2}s"
                : $"{ts.Seconds}s";
    }
}
