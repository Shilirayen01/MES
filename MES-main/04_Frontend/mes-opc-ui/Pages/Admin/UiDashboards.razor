@page "/admin/ui-dashboards"
@using mes_opc_ui.Services.AdminApi
@using Microsoft.AspNetCore.Components.Forms
@inject UiAdminApiClient Api
@inject NavigationManager Nav

<style>
    .ud-page {
        --white:       #ffffff;
        --bg-soft:     #f8fafc;
        --border:      #e8edf5;
        --border-soft: #f1f5f9;
        --accent:      #1e40af;
        --accent-dim:  rgba(30,64,175,0.07);
        --green-bg:    #d1fae5;
        --green-txt:   #065f46;
        --green-bdr:   #a7f3d0;
        --tag-bg:      #dbeafe;
        --tag-txt:     #1e40af;
        --tag-bdr:     #bfdbfe;
        --red:         #dc2626;
        --red-bg:      rgba(220,38,38,0.07);
        --red-bdr:     #fecaca;
        --text-900:    #0f172a;
        --text-navy:   #1e4d7b;
        --text-muted:  #64748b;
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text-900);
    }

    /* ── Header ── */
    .ud-page .page-header {
        display: flex; align-items: flex-end; justify-content: space-between;
        margin-bottom: 28px; padding-bottom: 18px; border-bottom: 1px solid var(--border);
    }
    .ud-page .page-header h3 {
        font-size: 24px; font-weight: 800; letter-spacing: -0.5px;
        color: var(--text-900); margin: 0 0 5px 0;
    }
    .ud-page .page-header p { font-size: 13px; color: var(--text-navy); margin: 0; }

    /* ── Buttons ── */
    .ud-page .ud-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; border: 1px solid transparent;
        font-family: inherit; line-height: 1.4; text-decoration: none;
    }
    .ud-page .ud-btn-primary {
        background: var(--accent); color: #fff; border-color: var(--accent);
    }
    .ud-page .ud-btn-primary:hover {
        background: #1e3a8a; box-shadow: 0 4px 14px rgba(30,64,175,0.25); transform: translateY(-1px);
    }
    .ud-page .ud-btn-ghost {
        background: var(--white); color: var(--text-muted); border-color: var(--border);
    }
    .ud-page .ud-btn-ghost:hover {
        color: var(--text-900); border-color: #c8d2e0; background: var(--bg-soft);
    }
    .ud-page .ud-btn-outline {
        background: var(--accent-dim); color: var(--accent);
        border-color: var(--tag-bdr); font-size: 12px; padding: 5px 12px; border-radius: 7px;
    }
    .ud-page .ud-btn-outline:hover { background: var(--tag-bg); }
    .ud-page .ud-btn-danger {
        background: var(--red); color: #fff; border-color: var(--red);
        font-size: 12px; padding: 5px 12px;
    }
    .ud-page .ud-btn-danger:hover {
        background: #b91c1c; box-shadow: 0 4px 12px rgba(220,38,38,0.25); transform: translateY(-1px);
    }
    .ud-page .ud-btn-icon {
        background: var(--bg-soft); color: var(--text-muted);
        border-color: var(--border); padding: 5px 10px; font-size: 13px; border-radius: 7px;
    }
    .ud-page .ud-btn-icon:hover {
        color: var(--accent); border-color: var(--tag-bdr); background: var(--accent-dim);
    }

    /* ── Alert ── */
    .ud-page .ud-alert-danger {
        background: var(--red-bg); border: 1px solid var(--red-bdr);
        color: var(--red); border-radius: 10px; padding: 12px 16px;
        font-size: 13px; margin-bottom: 16px;
    }
    .ud-page .loading-text { color: var(--text-navy); font-size: 13px; padding: 8px 0; }

    /* ── Dashboard Grid ── */
    .ud-page .dash-grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
    }
    @@media (max-width: 1100px) { .ud-page .dash-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 700px)  { .ud-page .dash-grid { grid-template-columns: 1fr; } }

    /* ── Dashboard Card ── */
    .ud-page .dash-card {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 14px; overflow: hidden; display: flex; flex-direction: column;
        transition: box-shadow 0.2s, transform 0.2s;
        animation: udFadeUp 0.4s ease both;
        box-shadow: 0 1px 4px rgba(15,23,42,0.05);
        cursor: pointer;
    }
    .ud-page .dash-card:hover {
        box-shadow: 0 6px 24px rgba(15,23,42,0.10); transform: translateY(-2px);
    }
    .ud-page .dash-card.is-default {
        border-color: var(--green-bdr);
        border-top: 3px solid var(--green-txt);
    }

    @@keyframes udFadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .ud-page .dash-card:nth-child(1) { animation-delay: 0.05s; }
    .ud-page .dash-card:nth-child(2) { animation-delay: 0.10s; }
    .ud-page .dash-card:nth-child(3) { animation-delay: 0.15s; }
    .ud-page .dash-card:nth-child(4) { animation-delay: 0.20s; }
    .ud-page .dash-card:nth-child(5) { animation-delay: 0.25s; }
    .ud-page .dash-card:nth-child(6) { animation-delay: 0.30s; }

    /* ── Card Body ── */
    .ud-page .dash-card-body { padding: 18px 18px 14px; flex: 1; }
    .ud-page .dash-card-top {
        display: flex; align-items: flex-start; justify-content: space-between;
        gap: 10px; margin-bottom: 10px;
    }
    .ud-page .dash-card-title {
        font-size: 15px; font-weight: 700; color: var(--text-900);
        margin: 0 0 4px 0; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .ud-page .badge-default {
        display: inline-flex; align-items: center; gap: 4px; padding: 2px 9px;
        border-radius: 5px; background: var(--green-bg); border: 1px solid var(--green-bdr);
        color: var(--green-txt); font-size: 10px; font-weight: 700; text-transform: uppercase;
    }
    .ud-page .badge-default::before {
        content: ''; width: 5px; height: 5px; border-radius: 50%;
        background: var(--green-txt); animation: udPulse 2s ease infinite;
    }
    @@keyframes udPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    .ud-page .dash-card-desc {
        font-size: 12px; color: var(--text-navy); min-height: 2em; line-height: 1.5;
    }

    /* ── Card Actions ── */
    .ud-page .dash-card-actions {
        display: flex; gap: 8px; align-items: center; margin-top: 14px;
    }
    .ud-page .dash-card-actions .ud-btn-outline { flex: 1; justify-content: center; }

    /* ── Card Footer ── */
    .ud-page .dash-card-footer {
        padding: 9px 18px; border-top: 1px solid var(--border-soft);
        font-size: 11px; color: var(--text-muted);
        font-family: 'JetBrains Mono', monospace; background: var(--bg-soft);
    }

    /* ── Modal backdrop ── */
    .ud-modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(15,23,42,0.45);
        backdrop-filter: blur(2px);
        z-index: 1000; display: flex; align-items: center; justify-content: center;
        animation: udFadeIn 0.15s ease;
    }
    @@keyframes udFadeIn { from { opacity: 0; } to { opacity: 1; } }

    .ud-modal {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 16px; width: 100%; max-width: 460px;
        box-shadow: 0 20px 50px rgba(15,23,42,0.18);
        animation: udSlideUp 0.2s ease;
        font-family: 'DM Sans', sans-serif; color: var(--text-900);
        border-top: 3px solid var(--accent);
    }
    @@keyframes udSlideUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .ud-modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 1px solid var(--border);
        background: var(--bg-soft); border-radius: 13px 13px 0 0;
    }
    .ud-modal-title {
        font-size: 15px; font-weight: 700; color: var(--text-900); margin: 0;
    }
    .ud-modal-title.danger { color: var(--red); }
    .ud-modal-close {
        background: transparent; border: none; color: var(--text-muted);
        font-size: 18px; cursor: pointer; padding: 2px 6px;
        border-radius: 6px; line-height: 1; transition: all 0.15s;
    }
    .ud-modal-close:hover { color: var(--text-900); background: var(--bg-soft); }
    .ud-modal-body { padding: 20px; }
    .ud-modal-footer {
        display: flex; justify-content: flex-end; gap: 10px;
        padding: 14px 20px; border-top: 1px solid var(--border);
        background: var(--bg-soft); border-radius: 0 0 13px 13px;
    }
    .ud-modal .form-group {
        display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px;
    }
    .ud-modal .form-group label {
        font-size: 11px; color: var(--text-navy); font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.5px;
    }
    .ud-page .ud-input {
        background: var(--bg-soft); border: 1.5px solid var(--border);
        color: var(--text-900); border-radius: 8px; padding: 8px 10px;
        font-size: 13px; font-family: inherit; width: 100%; transition: border-color 0.15s;
    }
    .ud-page .ud-input:focus {
        outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim);
    }
    .ud-modal .form-check-row {
        display: flex; align-items: center; gap: 8px; margin-top: 4px;
    }
    .ud-modal .form-check-row input[type="checkbox"] {
        width: 15px; height: 15px; accent-color: var(--accent); cursor: pointer;
    }
    .ud-modal .form-check-row label {
        font-size: 13px; color: var(--text-900); cursor: pointer;
        text-transform: none; letter-spacing: 0;
    }
    .ud-modal .delete-warning { font-size: 13px; color: var(--text-900); margin-bottom: 8px; }
    .ud-modal .delete-sub { font-size: 12px; color: var(--text-navy); }
    .ud-modal .validation-errors {
        background: var(--red-bg); border: 1px solid var(--red-bdr);
        border-radius: 8px; padding: 8px 12px; font-size: 12px;
        color: var(--red); margin-bottom: 14px;
    }
</style>

<div class="ud-page">

    @* ── Page Header ── *@
    <div class="page-header">
        <div>
            <h3>UI Dashboards</h3>
            <p>Gestion des dashboards (défaut, création, suppression)</p>
        </div>
        <button class="ud-btn ud-btn-primary" @onclick="New">+ Nouveau</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <div class="ud-alert-danger">@Error</div>
    }

    @if (Items is null)
    {
        <p class="loading-text">Chargement...</p>
    }
    else
    {
        <div style="margin-bottom: 20px;">
            <input type="text" class="ud-input" placeholder="Rechercher un dashboard..." @bind="_searchQuery" @bind:event="oninput" style="max-width: 300px;" />
        </div>
        <div class="dash-grid">
            @{
                var filtered = Items.Where(x => string.IsNullOrWhiteSpace(_searchQuery) || x.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)).OrderBy(x => x.Name);
            }
            @foreach (var d in filtered)
            {
                <div class="dash-card" @onclick="@(() => Nav.NavigateTo($"/dashboard/{d.Id}"))">
                    <div class="dash-card-body">
                        <div class="dash-card-top">
                            <div>
                                <div class="dash-card-title">
                                    @d.Name
                                </div>
                                <div class="dash-card-desc">
                                    @(!string.IsNullOrWhiteSpace(d.Description) ? d.Description : "—")
                                </div>
                            </div>
                            <div style="display: flex; gap: 6px;">
                                <button type="button" class="ud-btn ud-btn-icon" @onclick:stopPropagation="true" @onclick="() => Edit(d)" title="Modifier">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                                </button>
                                <button type="button" class="ud-btn ud-btn-icon" style="color: var(--red); border-color: var(--red-bdr);" @onclick:stopPropagation="true" @onclick="() => AskDelete(d)" title="Supprimer">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                </button>
                            </div>
                        </div>
                        <div class="dash-card-actions">
                            <button type="button" class="ud-btn ud-btn-outline" @onclick:stopPropagation="true" @onclick="() => Open(d.Id)">⚙ Gérer (Zones/Widgets)</button>
                        </div>
                    </div>
                    <div class="dash-card-footer">
                        Créé : @d.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </div>
                </div>
            }
        </div>
    }

    @* ── Modal Create/Edit ── *@
    @if (Form is not null)
    {
        <div class="ud-modal-backdrop" @onclick="CloseModal">
            <div class="ud-modal" @onclick:stopPropagation>
                <div class="ud-modal-header">
                    <h5 class="ud-modal-title">@(IsEdit ? "Modifier Dashboard" : "+ Créer Dashboard")</h5>
                    <button class="ud-modal-close" @onclick="CloseModal">✕</button>
                </div>
                <EditForm Model="Form" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <div class="ud-modal-body">
                        <ValidationSummary class="validation-errors" />
                        <div class="form-group">
                            <label>Nom</label>
                            <InputText class="ud-input" @bind-Value="Form.Name" placeholder="Nom du dashboard" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText class="ud-input" @bind-Value="Form.Description" placeholder="Description (optionnel)" />
                        </div>
                    </div>
                    <div class="ud-modal-footer">
                        <button class="ud-btn ud-btn-ghost" type="button" @onclick="CloseModal">Annuler</button>
                        <button class="ud-btn ud-btn-primary" type="submit">Enregistrer</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* ── Modal Confirm Delete ── *@
    @if (DeleteCandidate is not null)
    {
        <div class="ud-modal-backdrop" @onclick="CloseDelete">
            <div class="ud-modal" @onclick:stopPropagation>
                <div class="ud-modal-header" style="border-top-color:var(--red);">
                    <h5 class="ud-modal-title danger">Supprimer Dashboard</h5>
                    <button class="ud-modal-close" @onclick="CloseDelete">✕</button>
                </div>
                <div class="ud-modal-body">
                    <p class="delete-warning">
                        Confirmer la suppression de : <strong style="color:var(--accent)">@DeleteCandidate.Name</strong> ?
                    </p>
                    <p class="delete-sub">Zones, Widgets et Bindings associés seront également supprimés.</p>
                </div>
                <div class="ud-modal-footer">
                    <button class="ud-btn ud-btn-ghost" @onclick="CloseDelete">Annuler</button>
                    <button class="ud-btn ud-btn-danger" @onclick="ConfirmDelete">Supprimer</button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private string _searchQuery = "";
    private List<UiDashboardDto>? Items;
    private string? Error;

    private UiDashboardCreateDto? Form;
    private bool IsEdit;
    private Guid EditId;

    private UiDashboardDto? DeleteCandidate;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        Error = null; Items = null;
        try { Items = await Api.GetDashboardsAsync() ?? []; }
        catch (Exception ex) { Error = ex.Message; Items = []; }
    }

    private void Open(Guid id) => Nav.NavigateTo($"/admin/ui-dashboards/{id}");

    private void New() { IsEdit = false; EditId = Guid.Empty; Form = new UiDashboardCreateDto(); }

    private void Edit(UiDashboardDto d)
    {
        IsEdit = true; EditId = d.Id;
        Form = new UiDashboardCreateDto { Name = d.Name, Description = d.Description, IsDefault = d.IsDefault };
    }

    private async Task Save()
    {
        if (Form is null) return;
        try
        {
            if (!IsEdit)
                await Api.CreateDashboardAsync(Form);
            else
                await Api.UpdateDashboardAsync(EditId, new UiDashboardUpdateDto { Name = Form.Name, Description = Form.Description, IsDefault = Form.IsDefault });
            CloseModal(); await Load();
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task SetDefault(Guid id)
    {
        try { await Api.SetDefaultDashboardAsync(id); await Load(); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private void CloseModal() => Form = null;
    private void AskDelete(UiDashboardDto d) => DeleteCandidate = d;
    private void CloseDelete() => DeleteCandidate = null;

    private async Task ConfirmDelete()
    {
        if (DeleteCandidate is null) return;
        try { await Api.DeleteDashboardAsync(DeleteCandidate.Id); DeleteCandidate = null; await Load(); }
        catch (Exception ex) { Error = ex.Message; }
    }
}
