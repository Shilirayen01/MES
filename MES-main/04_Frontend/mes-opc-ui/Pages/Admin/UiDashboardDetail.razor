@page "/admin/ui-dashboards/{DashboardId:guid}"
@using Microsoft.AspNetCore.Components.Forms
@using mes_opc_ui.Services.AdminApi
@inject UiAdminApiClient Api
@inject NavigationManager Nav

<style>
    .um-page {
        --white:       #ffffff;
        --bg-soft:     #f8fafc;
        --border:      #e8edf5;
        --border-soft: #f1f5f9;
        --accent:      #1e40af;
        --accent-dim:  rgba(30,64,175,0.07);
        --green-bg:    #d1fae5;
        --green-txt:   #065f46;
        --green-bdr:   #a7f3d0;
        --tag-bg:      #dbeafe;
        --tag-txt:     #1e40af;
        --tag-bdr:     #bfdbfe;
        --pink:        #be185d;
        --red:         #dc2626;
        --red-bg:      rgba(220,38,38,0.07);
        --red-bdr:     #fecaca;
        --orange-bg:   #fffbeb;
        --orange-bdr:  #fde68a;
        --orange-txt:  #92400e;
        --text-900:    #0f172a;
        --text-navy:   #1e4d7b;
        --text-muted:  #64748b;
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text-900);
    }

    /* ── Header ── */
    .um-page .page-header {
        display: flex; align-items: flex-end; justify-content: space-between;
        margin-bottom: 28px; padding-bottom: 18px; border-bottom: 1px solid var(--border);
    }
    .um-page .page-header h3 {
        font-size: 24px; font-weight: 800; letter-spacing: -0.5px;
        color: var(--text-900); margin: 0 0 5px 0;
    }
    .um-page .page-header p {
        font-size: 12px; color: var(--text-navy); margin: 0;
        font-family: 'JetBrains Mono', monospace;
    }

    /* ── Buttons ── */
    .um-page .um-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; border: 1px solid transparent;
        font-family: inherit; line-height: 1.4;
    }
    .um-page .um-btn-primary {
        background: var(--accent); color: #fff; border-color: var(--accent);
    }
    .um-page .um-btn-primary:hover {
        background: #1e3a8a; box-shadow: 0 4px 14px rgba(30,64,175,0.25); transform: translateY(-1px);
    }
    .um-page .um-btn-primary:disabled {
        opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none;
    }
    .um-page .um-btn-ghost {
        background: var(--white); color: var(--text-muted); border-color: var(--border);
    }
    .um-page .um-btn-ghost:hover {
        color: var(--text-900); border-color: #c8d2e0; background: var(--bg-soft);
    }
    .um-page .um-btn-outline {
        background: var(--accent-dim); color: var(--accent);
        border-color: var(--tag-bdr); font-size: 11px; padding: 3px 10px; border-radius: 6px;
    }
    .um-page .um-btn-outline:hover { background: var(--tag-bg); }
    .um-page .um-btn-danger-sm {
        background: var(--red-bg); color: var(--red);
        border-color: var(--red-bdr); font-size: 11px; padding: 3px 10px; border-radius: 6px;
    }
    .um-page .um-btn-danger-sm:hover { background: #fee2e2; }
    .um-page .um-btn-danger {
        background: var(--red); color: #fff; border-color: var(--red);
    }
    .um-page .um-btn-danger:hover {
        background: #b91c1c; box-shadow: 0 4px 12px rgba(220,38,38,0.25); transform: translateY(-1px);
    }

    /* ── Alert ── */
    .um-page .um-alert-danger {
        background: var(--red-bg); border: 1px solid var(--red-bdr);
        color: var(--red); border-radius: 10px; padding: 12px 16px;
        font-size: 13px; margin-bottom: 16px;
    }

    /* ── 3-column layout ── */
    .um-page .three-col {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        align-items: start;
    }
    @@media (max-width: 1100px) { .um-page .three-col { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 700px)  { .um-page .three-col { grid-template-columns: 1fr; } }

    /* ── Panel Card ── */
    .um-page .panel-card {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 14px; overflow: hidden;
        box-shadow: 0 1px 4px rgba(15,23,42,0.05);
        animation: umFadeUp 0.35s ease both;
    }
    .um-page .panel-card:nth-child(1) { animation-delay: 0.05s; }
    .um-page .panel-card:nth-child(2) { animation-delay: 0.10s; }
    .um-page .panel-card:nth-child(3) { animation-delay: 0.15s; }
    @@keyframes umFadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .um-page .panel-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 13px 16px; border-bottom: 1px solid var(--border); background: var(--bg-soft);
    }
    .um-page .panel-title {
        font-size: 13px; font-weight: 700; color: var(--text-900);
        display: flex; align-items: center; gap: 8px;
    }
    .um-page .panel-count {
        display: inline-flex; align-items: center; padding: 1px 8px;
        border-radius: 10px; background: var(--accent-dim);
        border: 1px solid var(--tag-bdr); color: var(--accent);
        font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700;
    }

    /* ── List Items ── */
    .um-page .list-empty {
        padding: 16px; font-size: 12px; color: var(--text-muted); font-style: italic;
    }
    .um-page .list-item {
        display: block; width: 100%; text-align: left;
        padding: 12px 16px; border: none;
        border-bottom: 1px solid var(--border-soft);
        background: transparent; cursor: pointer;
        transition: background 0.15s; font-family: inherit; color: var(--text-900);
    }
    .um-page .list-item:last-child { border-bottom: none; }
    .um-page .list-item:hover { background: #eff6ff; }
    .um-page .list-item.active {
        background: var(--accent-dim);
        border-left: 3px solid var(--accent);
        padding-left: 13px;
    }
    .um-page .list-item-top {
        display: flex; align-items: flex-start;
        justify-content: space-between; gap: 8px; margin-bottom: 0;
    }
    .um-page .list-item-title {
        font-size: 13px; font-weight: 600; color: var(--text-900);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .um-page .list-item-sub {
        font-size: 11px; color: var(--text-navy); margin-top: 2px;
    }
    .um-page .list-item-actions { display: flex; gap: 6px; flex-shrink: 0; }

    /* ── Bindings Table ── */
    .um-page .bindings-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .um-page .bindings-table th {
        text-align: left; padding: 8px 14px; color: var(--text-navy);
        font-size: 10px; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.5px; border-bottom: 1px solid var(--border);
        background: var(--bg-soft); white-space: nowrap;
    }
    .um-page .bindings-table td {
        padding: 9px 14px; color: var(--text-900);
        border-bottom: 1px solid var(--border-soft); vertical-align: middle;
    }
    .um-page .bindings-table tbody tr:last-child td { border-bottom: none; }
    .um-page .bindings-table tbody tr:hover td { background: #eff6ff; }
    .um-page .cell-machine {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        font-weight: 700; color: var(--accent);
    }
    .um-page .cell-role { font-size: 11px; color: var(--pink); font-weight: 600; }
    .um-page .cell-nodeid {
        font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-navy);
        max-width: 200px; overflow: hidden; text-overflow: ellipsis;
        white-space: nowrap; display: block;
    }
    .um-page .cell-actions-td { white-space: nowrap; text-align: right; }
    .um-page .cell-actions-td .um-btn { margin-left: 4px; }

    /* ── Modal backdrop ── */
    .um-modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(15,23,42,0.45);
        backdrop-filter: blur(2px);
        z-index: 1000; display: flex; align-items: center; justify-content: center;
        animation: umFadeIn 0.15s ease;
    }
    @@keyframes umFadeIn { from { opacity: 0; } to { opacity: 1; } }

    .um-modal {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 16px; width: 100%; max-width: 460px;
        box-shadow: 0 20px 50px rgba(15,23,42,0.18);
        animation: umSlideUp 0.2s ease;
        font-family: 'DM Sans', sans-serif; color: var(--text-900);
        border-top: 3px solid var(--accent);
    }
    @@keyframes umSlideUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .um-modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 15px 20px; border-bottom: 1px solid var(--border);
        background: var(--bg-soft); border-radius: 13px 13px 0 0;
    }
    .um-modal-title {
        font-size: 15px; font-weight: 700; color: var(--text-900); margin: 0;
    }
    .um-modal-close {
        background: transparent; border: none; color: var(--text-muted);
        font-size: 18px; cursor: pointer; padding: 2px 6px;
        border-radius: 6px; line-height: 1; transition: all 0.15s;
    }
    .um-modal-close:hover { color: var(--text-900); background: var(--bg-soft); }
    .um-modal-body { padding: 20px; }
    .um-modal-footer {
        display: flex; justify-content: flex-end; gap: 10px;
        padding: 14px 20px; border-top: 1px solid var(--border);
        background: var(--bg-soft); border-radius: 0 0 13px 13px;
    }
    .um-modal .form-group {
        display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px;
    }
    .um-modal .form-group label {
        font-size: 11px; color: var(--text-navy); font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.5px;
    }
    .um-modal .um-input {
        background: var(--bg-soft); border: 1.5px solid var(--border);
        color: var(--text-900); border-radius: 8px; padding: 8px 10px;
        font-size: 13px; font-family: inherit; width: 100%; transition: border-color 0.15s;
    }
    .um-modal .um-input:focus {
        outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim);
    }
    .um-modal .um-input.mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; }
    .um-modal .validation-errors {
        background: var(--red-bg); border: 1px solid var(--red-bdr);
        border-radius: 8px; padding: 8px 12px; font-size: 12px;
        color: var(--red); margin-bottom: 14px;
    }

    /* ── Assistant Machine ── */
    .um-assistant-modal {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 16px; width: 100%; max-width: 520px;
        box-shadow: 0 20px 50px rgba(15,23,42,0.18);
        animation: umSlideUp 0.2s ease;
        font-family: 'DM Sans', sans-serif; color: var(--text-900);
        border-top: 3px solid #7c3aed;
        
        /* FIX : Empêcher le modal de sortir de l'écran */
        max-height: 90vh;
        display: flex;
        flex-direction: column;
    }
    .um-assistant-modal .um-modal-header { border-top-color: #7c3aed; flex-shrink: 0; }
    .um-assistant-modal .um-modal-body { overflow-y: auto; flex: 1; }
    .um-assistant-modal .um-modal-footer { flex-shrink: 0; }
    .um-assistant-modal .um-modal-title { color: #7c3aed; }
    .asst-step-indicator {
        display: flex; gap: 6px; align-items: center;
        margin-bottom: 18px;
    }
    .asst-step-dot {
        width: 28px; height: 6px; border-radius: 3px;
        background: var(--border); transition: background 0.2s;
    }
    .asst-step-dot.active { background: #7c3aed; }
    .asst-step-dot.done { background: #a78bfa; }
    .asst-radio-group { display: flex; flex-direction: column; gap: 10px; margin: 4px 0 8px; }
    .asst-radio-option {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 14px; border: 1.5px solid var(--border);
        border-radius: 10px; cursor: pointer; transition: all 0.15s;
        font-size: 13px; font-weight: 500;
    }
    .asst-radio-option:hover { border-color: #a78bfa; background: #f5f3ff; }
    .asst-radio-option.selected { border-color: #7c3aed; background: #f5f3ff; color: #7c3aed; font-weight: 600; }
    .asst-radio-option input[type=radio] { accent-color: #7c3aed; width: 16px; height: 16px; }
    .asst-machine-list {
        max-height: 220px; overflow-y: auto;
        border: 1.5px solid var(--border); border-radius: 10px;
        margin-top: 6px;
    }
    .asst-machine-item {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 14px; border-bottom: 1px solid var(--border-soft);
        font-size: 13px; cursor: pointer; transition: background 0.12s;
    }
    .asst-machine-item:last-child { border-bottom: none; }
    .asst-machine-item:hover { background: #f5f3ff; }
    .asst-machine-item input[type=checkbox] { accent-color: #7c3aed; width: 15px; height: 15px; }
    /* ── Tag search bar ── */
    .asst-tag-search-bar {
        display: flex; gap: 8px; align-items: center; margin-bottom: 8px;
    }
    .asst-tag-search-input {
        flex: 1; padding: 7px 12px; border-radius: 8px;
        border: 1.5px solid var(--border); font-size: 12px; font-family: inherit;
        outline: none; transition: border-color 0.15s; background: var(--white);
    }
    .asst-tag-search-input:focus { border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.10); }
    .asst-tag-search-input::placeholder { color: var(--text-muted); }
    .asst-btn-filter {
        padding: 7px 12px; border-radius: 8px; font-size: 11px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; border: 1.5px solid #7c3aed;
        white-space: nowrap; font-family: inherit;
        background: var(--white); color: #7c3aed;
    }
    .asst-btn-filter.active { background: #7c3aed; color: #fff; }
    .asst-tag-list {
        max-height: 240px; overflow-y: auto;
        border: 1.5px solid var(--border); border-radius: 10px;
        margin-top: 6px;
    }
    .asst-tag-item {
        display: flex; align-items: center; gap: 8px;
        padding: 9px 14px; border-bottom: 1px solid var(--border-soft);
        font-size: 12px; cursor: pointer; transition: background 0.12s;
    }
    .asst-tag-item:last-child { border-bottom: none; }
    .asst-tag-item:hover { background: #f5f3ff; }
    .asst-tag-item input[type=checkbox] { accent-color: #7c3aed; width: 14px; height: 14px; flex-shrink: 0; }
    .asst-tag-nodeid { font-family: 'JetBrains Mono', monospace; flex: 1; font-size: 11px; color: var(--text-navy); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .asst-role-select {
        padding: 3px 6px; border-radius: 6px; border: 1px solid var(--border);
        font-size: 11px; background: var(--white); color: var(--accent);
        font-weight: 600; cursor: pointer; font-family: inherit;
    }
    .asst-summary-zone {
        background: var(--bg-soft); border: 1px solid var(--border);
        border-radius: 8px; padding: 10px 14px; margin-bottom: 8px; font-size: 12px;
    }
    .asst-summary-zone-title { font-weight: 700; color: var(--text-900); margin-bottom: 4px; font-size: 13px; }
    .asst-summary-row { display: flex; gap: 6px; align-items: center; padding: 2px 0; }
    .asst-summary-tag { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-navy); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .asst-summary-role { font-size: 10px; font-weight: 700; color: #7c3aed; flex-shrink: 0; }
    .asst-btn-violet {
        background: #7c3aed; color: #fff; border-color: #7c3aed;
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; border: 1px solid transparent;
        font-family: inherit; line-height: 1.4;
    }
    .asst-btn-violet:hover { background: #6d28d9; box-shadow: 0 4px 14px rgba(124,58,237,0.3); transform: translateY(-1px); }
    .asst-btn-violet:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }
    .asst-select {
        background: var(--bg-soft); border: 1.5px solid var(--border);
        color: var(--text-900); border-radius: 8px; padding: 8px 10px;
        font-size: 13px; font-family: inherit; width: 100%; transition: border-color 0.15s;
    }
    .asst-select:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.1); }
    .asst-input {
        background: var(--bg-soft); border: 1.5px solid var(--border);
        color: var(--text-900); border-radius: 8px; padding: 8px 10px;
        font-size: 13px; font-family: inherit; width: 100%; transition: border-color 0.15s;
    }
    .asst-input:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.1); }
    .asst-info { font-size: 12px; color: var(--text-navy); margin-bottom: 10px; }
    .asst-loading { font-size: 12px; color: var(--text-muted); font-style: italic; padding: 8px 0; }
    .asst-btn-header {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 14px; border-radius: 8px; font-size: 12px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; border: 1.5px solid #a78bfa;
        background: #f5f3ff; color: #7c3aed; font-family: inherit;
    }
    .asst-btn-header:hover { background: #ede9fe; box-shadow: 0 2px 8px rgba(124,58,237,0.15); }
</style>

<div class="um-page">

    @* ── Page Header ── *@
    <div class="page-header">
        <div>
            <h3>UI Management</h3>
            <p>Dashboard : @DashboardId</p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
            <button class="asst-btn-header" @onclick="OpenAssistant">Assistant Machine</button>
            <button class="um-btn um-btn-ghost" @onclick="Back">← Retour</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <div class="um-alert-danger">@Error</div>
    }

    <div class="three-col">

        @* ── Zones Panel ── *@
        <div class="panel-card">
            <div class="panel-header">
                <div class="panel-title">
                    Zones
                    @if (Zones is not null) { <span class="panel-count">@Zones.Count</span> }
                </div>
                <button class="um-btn um-btn-primary" style="padding:4px 12px;font-size:12px;" @onclick="NewZone">+ Zone</button>
            </div>
            @if (Zones is null) { <div class="list-empty">Chargement...</div> }
            else if (Zones.Count == 0) { <div class="list-empty">Aucune zone.</div> }
            else
            {
                @foreach (var z in Zones.OrderBy(x => x.OrderIndex))
                {
                    var active = z.Id == SelectedZoneId;
                    <button class="list-item @(active ? "active" : "")" @onclick="() => SelectZone(z.Id)">
                        <div class="list-item-top">
                            <div>
                                <div class="list-item-title">@z.Title</div>
                                <div class="list-item-sub">@z.LayoutType · ordre @z.OrderIndex</div>
                            </div>
                            <div class="list-item-actions">
                                <button type="button" class="um-btn um-btn-outline"
                                        @onclick:stopPropagation="true" @onclick="() => EditZone(z)">Edit</button>
                                <button type="button" class="um-btn um-btn-danger-sm"
                                        @onclick:stopPropagation="true" @onclick="() => DeleteZone(z.Id)">Suppr.</button>
                            </div>
                        </div>
                    </button>
                }
            }
        </div>

        @* ── Widgets Panel ── *@
        <div class="panel-card">
            <div class="panel-header">
                <div class="panel-title">
                    Widgets
                    @if (Widgets is not null) { <span class="panel-count">@Widgets.Count</span> }
                </div>
                <button class="um-btn um-btn-primary" style="padding:4px 12px;font-size:12px;"
                        @onclick="NewWidget" disabled="@(SelectedZoneId == Guid.Empty)">+ Widget</button>
            </div>
            @if (SelectedZoneId == Guid.Empty) { <div class="list-empty">Sélectionne une zone.</div> }
            else if (Widgets is null) { <div class="list-empty">Chargement...</div> }
            else if (Widgets.Count == 0) { <div class="list-empty">Aucun widget.</div> }
            else
            {
                @foreach (var w in Widgets.OrderBy(x => x.OrderIndex))
                {
                    var activeW = w.Id == SelectedWidgetId;
                    <button class="list-item @(activeW ? "active" : "")" @onclick="() => SelectWidget(w.Id)">
                        <div class="list-item-top">
                            <div>
                                <div class="list-item-title">@w.Title</div>
                                <div class="list-item-sub">@w.WidgetType · ordre @w.OrderIndex</div>
                            </div>
                            <div class="list-item-actions">
                                <button type="button" class="um-btn um-btn-outline"
                                        @onclick:stopPropagation="true" @onclick="() => EditWidget(w)">Edit</button>
                                <button type="button" class="um-btn um-btn-danger-sm"
                                        @onclick:stopPropagation="true" @onclick="() => DeleteWidget(w.Id)">Suppr.</button>
                            </div>
                        </div>
                    </button>
                }
            }
        </div>

        @* ── Bindings Panel ── *@
        <div class="panel-card">
            <div class="panel-header">
                <div class="panel-title">
                    Bindings
                    @if (Bindings is not null) { <span class="panel-count">@Bindings.Count</span> }
                </div>
                <button class="um-btn um-btn-primary" style="padding:4px 12px;font-size:12px;"
                        @onclick="NewBinding" disabled="@(SelectedWidgetId == Guid.Empty)">+ Binding</button>
            </div>
            @if (SelectedWidgetId == Guid.Empty) { <div class="list-empty">Sélectionne un widget.</div> }
            else if (Bindings is null) { <div class="list-empty">Chargement...</div> }
            else if (Bindings.Count == 0) { <div class="list-empty">Aucun binding.</div> }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="bindings-table">
                        <thead>
                            <tr>
                                <th>Machine</th>
                                <th>Role</th>
                                <th>OpcNodeId</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Bindings)
                            {
                                <tr>
                                    <td><span class="cell-machine">@b.MachineCode</span></td>
                                    <td><span class="cell-role">@b.BindingRole</span></td>
                                    <td><span class="cell-nodeid">@b.OpcNodeId</span></td>
                                    <td class="cell-actions-td">
                                        <button class="um-btn um-btn-outline" @onclick="() => EditBinding(b)">Edit</button>
                                        <button class="um-btn um-btn-danger-sm" @onclick="() => DeleteBinding(b.Id)">Suppr.</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>

    @* ── Modal Zone ── *@
    @if (ZoneForm is not null)
    {
        <div class="um-modal-backdrop" @onclick="CloseZone">
            <div class="um-modal" @onclick:stopPropagation>
                <div class="um-modal-header">
                    <h5 class="um-modal-title">@(ZoneEditId == Guid.Empty ? "+ Créer Zone" : "✏ Modifier Zone")</h5>
                    <button class="um-modal-close" @onclick="CloseZone">✕</button>
                </div>
                <EditForm Model="ZoneForm" OnValidSubmit="SaveZone">
                    <DataAnnotationsValidator />
                    <div class="um-modal-body">
                        <ValidationSummary class="validation-errors" />
                        <div class="form-group"><label>Title</label><InputText class="um-input" @bind-Value="ZoneForm.Title" placeholder="Nom de la zone" /></div>
                        <div class="form-group"><label>Layout Type</label><InputText class="um-input" @bind-Value="ZoneForm.LayoutType" placeholder="ex: grid, flex" /></div>
                        <div class="form-group"><label>Props JSON</label><InputText class="um-input mono" @bind-Value="ZoneForm.PropsJson" placeholder="{}" /></div>
                        <div class="form-group"><label>Order Index</label><InputNumber class="um-input" TValue="int" @bind-Value="ZoneForm.OrderIndex" /></div>
                    </div>
                    <div class="um-modal-footer">
                        <button type="button" class="um-btn um-btn-ghost" @onclick="CloseZone">Annuler</button>
                        <button type="submit" class="um-btn um-btn-primary">Enregistrer</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* ── Modal Widget ── *@
    @if (WidgetForm is not null)
    {
        <div class="um-modal-backdrop" @onclick="CloseWidget">
            <div class="um-modal" @onclick:stopPropagation>
                <div class="um-modal-header">
                    <h5 class="um-modal-title">@(WidgetEditId == Guid.Empty ? "+ Créer Widget" : "✏ Modifier Widget")</h5>
                    <button class="um-modal-close" @onclick="CloseWidget">✕</button>
                </div>
                <EditForm Model="WidgetForm" OnValidSubmit="SaveWidget">
                    <DataAnnotationsValidator />
                    <div class="um-modal-body">
                        <ValidationSummary class="validation-errors" />
                        <div class="form-group"><label>Title</label><InputText class="um-input" @bind-Value="WidgetForm.Title" placeholder="Nom du widget" /></div>
                        <div class="form-group"><label>Widget Type</label><InputText class="um-input" @bind-Value="WidgetForm.WidgetType" placeholder="ex: gauge, chart" /></div>
                        <div class="form-group"><label>Props JSON</label><InputText class="um-input mono" @bind-Value="WidgetForm.PropsJson" placeholder="{}" /></div>
                        <div class="form-group"><label>Order Index</label><InputNumber class="um-input" TValue="int" @bind-Value="WidgetForm.OrderIndex" /></div>
                    </div>
                    <div class="um-modal-footer">
                        <button type="button" class="um-btn um-btn-ghost" @onclick="CloseWidget">Annuler</button>
                        <button type="submit" class="um-btn um-btn-primary">Enregistrer</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* ── Modal Binding ── *@
    @if (BindingForm is not null)
    {
        <div class="um-modal-backdrop" @onclick="CloseBinding">
            <div class="um-modal" @onclick:stopPropagation>
                <div class="um-modal-header">
                    <h5 class="um-modal-title">@(BindingEditId == Guid.Empty ? "+ Créer Binding" : "✏ Modifier Binding")</h5>
                    <button class="um-modal-close" @onclick="CloseBinding">✕</button>
                </div>
                <EditForm Model="BindingForm" OnValidSubmit="SaveBinding">
                    <DataAnnotationsValidator />
                    <div class="um-modal-body">
                        <ValidationSummary class="validation-errors" />
                        <div class="form-group"><label>Machine Code</label><InputText class="um-input mono" @bind-Value="BindingForm.MachineCode" placeholder="MC_03" /></div>
                        <div class="form-group"><label>OPC Node Id</label><InputText class="um-input mono" @bind-Value="BindingForm.OpcNodeId" placeholder="ns=2;i=..." /></div>
                        <div class="form-group"><label>Binding Role</label><InputText class="um-input" @bind-Value="BindingForm.BindingRole" placeholder="ex: value, label" /></div>
                    </div>
                    <div class="um-modal-footer">
                        <button type="button" class="um-btn um-btn-ghost" @onclick="CloseBinding">Annuler</button>
                        <button type="submit" class="um-btn um-btn-primary">Enregistrer</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* ── Modal Assistant Machine ── *@
    @if (_assistantStep > 0)
    {
        <div class="um-modal-backdrop" @onclick="CloseAssistant">
            <div class="um-assistant-modal" @onclick:stopPropagation>
                <div class="um-modal-header">
                    <h5 class="um-modal-title">Assistant Machine</h5>
                    <button class="um-modal-close" @onclick="CloseAssistant">✕</button>
                </div>
                <div class="um-modal-body">

                    @* Indicateur d'étapes *@
                    <div class="asst-step-indicator">
                        @for (int i = 1; i <= 4; i++)
                        {
                            var si = i;
                            var cls = si < _assistantStep ? "asst-step-dot done" : si == _assistantStep ? "asst-step-dot active" : "asst-step-dot";
                            <div class="@cls"></div>
                        }
                        <span style="font-size:11px;color:var(--text-muted);margin-left:4px;">Étape @_assistantStep / 4</span>
                    </div>

                    @* ── ÉTAPE 1 : Mode ── *@
                    @if (_assistantStep == 1)
                    {
                        <div class="form-group" style="margin-bottom:8px;">
                            <label style="font-size:12px;font-weight:600;color:var(--text-navy);">Que souhaitez-vous configurer ?</label>
                        </div>
                        <div class="asst-radio-group">
                            <label class="asst-radio-option @(_assistantMode == 0 ? "selected" : "")">
                                <input type="radio" name="asst_mode" checked="@(_assistantMode == 0)" @onchange="() => _assistantMode = 0" />
                                Une machine seule
                            </label>
                            <label class="asst-radio-option @(_assistantMode == 1 ? "selected" : "")">
                                <input type="radio" name="asst_mode" checked="@(_assistantMode == 1)" @onchange="() => _assistantMode = 1" />
                                Un groupe de machines (zone)
                            </label>
                        </div>
                    }

                    @* ── ÉTAPE 2 : Sélection machine(s) ── *@
                    @if (_assistantStep == 2)
                    {
                        @if (_assistantMode == 0)
                        {
                            <div class="form-group">
                                <label style="font-size:11px;font-weight:600;color:var(--text-navy);text-transform:uppercase;letter-spacing:.5px;">Machine</label>
                                @if (_asstMachines is null)
                                {
                                    <p class="asst-loading">Chargement des machines...</p>
                                }
                                else
                                {
                                    <select class="asst-select" value="@_asstSelectedSingle" @onchange="e => _asstSelectedSingle = e.Value?.ToString() ?? string.Empty">
                                        <option value="">-- Choisir une machine --</option>
                                        @foreach (var m in _asstMachines)
                                        {
                                            <option value="@m.MachineCode">@m.MachineCode</option>
                                        }
                                    </select>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="form-group">
                                <label style="font-size:11px;font-weight:600;color:var(--text-navy);text-transform:uppercase;letter-spacing:.5px;">Nom du groupe (zone)</label>
                                <input class="asst-input" type="text" placeholder="Ex: Lignes Presses" value="@_asstGroupName" @oninput="e => _asstGroupName = e.Value?.ToString() ?? string.Empty" />
                            </div>
                            <div class="form-group">
                                <label style="font-size:11px;font-weight:600;color:var(--text-navy);text-transform:uppercase;letter-spacing:.5px;">Machines à inclure</label>
                                @if (_asstMachines is null)
                                {
                                    <p class="asst-loading">Chargement des machines...</p>
                                }
                                else
                                {
                                    <div class="asst-machine-list">
                                        @foreach (var m in _asstMachines)
                                        {
                                            var mc = m.MachineCode;
                                            <label class="asst-machine-item">
                                                <input type="checkbox" checked="@_asstSelectedGroup.Contains(mc)"
                                                       @onchange="e => ToggleMachineGroup(mc, (bool)(e.Value ?? false))" />
                                                <span style="font-family:'JetBrains Mono',monospace;font-size:12px;">@mc</span>
                                            </label>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }

                    @* ── ÉTAPE 3 : Tags à afficher ── *@
                    @if (_assistantStep == 3)
                    {
                        @if (_asstTagsLoading)
                        {
                            <p class="asst-loading">⏳ Chargement des tags...</p>
                        }
                        else if (_asstCommonTags.Count == 0)
                        {
                            <p class="asst-info" style="color:var(--red);">Aucun tag trouvé pour les machines sélectionnées.</p>
                        }
                        else
                        {
                            <p class="asst-info">
                                @(_assistantMode == 1
                                    ? $"Tous les tags disponibles sur les {_asstSelectedGroup.Count} machines sélectionnées :"
                                    : $"Tags disponibles sur {_asstSelectedSingle} :")
                            </p>
                            <div class="asst-tag-search-bar">
                                <input class="asst-tag-search-input"
                                       type="text"
                                       placeholder="Rechercher un tag..."
                                       value="@_asstTagSearch"
                                       @oninput="e => _asstTagSearch = e.Value?.ToString() ?? string.Empty" />
                                <button class="asst-btn-filter" @onclick="SelectAllFilteredTags">Tout</button>
                                <button class="asst-btn-filter" @onclick="DeselectAllFilteredTags">Aucun</button>
                                <button class="asst-btn-filter @(_asstShowSelectedOnly ? "active" : "")"
                                        @onclick="() => _asstShowSelectedOnly = !_asstShowSelectedOnly">
                                    @(_asstShowSelectedOnly ? "Tous les tags" : "Selectionnes uniquement")
                                </button>
                            </div>
                            <div class="asst-tag-list">
                                @{
                                    var filteredTags = _asstCommonTags
                                        .Where(t => string.IsNullOrEmpty(_asstTagSearch) || t.OpcNodeId.Contains(_asstTagSearch, StringComparison.OrdinalIgnoreCase))
                                        .Where(t => !_asstShowSelectedOnly || _asstSelectedTags.ContainsKey(t.OpcNodeId))
                                        .ToList();
                                }
                                @if (filteredTags.Count == 0)
                                {
                                    <div style="padding:14px 16px;color:var(--text-muted);font-size:12px;font-style:italic;">Aucun tag correspondant.</div>
                                }
                                @foreach (var tag in filteredTags)
                                {
                                    var nodeId = tag.OpcNodeId;
                                    var isChecked = _asstSelectedTags.ContainsKey(nodeId);
                                    <div class="asst-tag-item">
                                        <input type="checkbox" checked="@isChecked"
                                               @onchange="e => ToggleTag(nodeId, (bool)(e.Value ?? false))" />
                                        <span class="asst-tag-nodeid" title="@nodeId">@nodeId</span>
                                        @if (isChecked)
                                        {
                                            <select class="asst-role-select"
                                                    value="@_asstSelectedTags[nodeId]"
                                                    @onchange="@(e => SetTagRole(nodeId, e.Value?.ToString() ?? "Value"))">
                                                <option value="Value">Value</option>
                                                <option value="Status">Status</option>
                                                <option value="Counter">Counter</option>
                                                <option value="Summary">Summary</option>
                                            </select>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }

                    @* ── ÉTAPE 4 : Récapitulatif ── *@
                    @if (_assistantStep == 4)
                    {
                        @if (_asstGenerating)
                        {
                            <p class="asst-loading">⏳ Génération en cours...</p>
                        }
                        else
                        {
                            var machines = _assistantMode == 0
                                ? new List<string> { _asstSelectedSingle }
                                : _asstSelectedGroup.ToList();
                            @foreach (var mc in machines)
                            {
                                <div class="asst-summary-zone">
                                    <div class="asst-summary-zone-title">Zone : @mc</div>
                                    @foreach (var kv in _asstSelectedTags)
                                    {
                                        <div class="asst-summary-row">
                                            <span>-&gt;</span>
                                            <span class="asst-summary-tag" title="@kv.Key">@kv.Key</span>
                                            <span class="asst-summary-role">@kv.Value</span>
                                        </div>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_asstError))
                            {
                                <div class="um-alert-danger" style="margin-top:10px;">@_asstError</div>
                            }
                        }
                    }

                </div>
                <div class="um-modal-footer">
                    @if (_assistantStep > 1)
                    {
                        <button class="um-btn um-btn-ghost" @onclick="AssistantBack" disabled="@_asstGenerating">← Retour</button>
                    }
                    else
                    {
                        <button class="um-btn um-btn-ghost" @onclick="CloseAssistant">Annuler</button>
                    }
                    @if (_assistantStep < 4)
                    {
                        <button class="asst-btn-violet" @onclick="AssistantNext" disabled="@(!CanGoNext())">Suivant</button>
                    }
                    else
                    {
                        <button class="asst-btn-violet" @onclick="GenerateAsync" disabled="@(_asstGenerating || _asstSelectedTags.Count == 0)">Générer tout</button>
                    }
                </div>
            </div>
        </div>
    }

</div>

@code {
    [Parameter] public Guid DashboardId { get; set; }

    private string? Error;

    // ── Assistant Machine state ──
    private int _assistantStep = 0;       // 0=fermé, 1-4=étapes
    private int _assistantMode = 0;       // 0=machine seule, 1=groupe
    private List<MachineDto>? _asstMachines;
    private string _asstSelectedSingle = "";
    private HashSet<string> _asstSelectedGroup = new();
    private string _asstGroupName = "";
    private List<TagMappingDto> _asstCommonTags = new();
    private Dictionary<string, string> _asstSelectedTags = new();
    private bool _asstTagsLoading = false;
    private bool _asstGenerating = false;
    private string? _asstError;
    private string _asstTagSearch = "";
    private bool _asstShowSelectedOnly = false;

    private List<UiZoneDto>? Zones;
    private Guid SelectedZoneId;
    private List<UiWidgetDto>? Widgets;
    private Guid SelectedWidgetId;
    private List<UiWidgetBindingDto>? Bindings;

    private UiZoneCreateDto? ZoneForm;
    private Guid ZoneEditId;

    private UiWidgetCreateDto? WidgetForm;
    private Guid WidgetEditId;

    private UiWidgetBindingCreateDto? BindingForm;
    private Guid BindingEditId;

    protected override async Task OnParametersSetAsync() => await LoadZones();

    private void Back() => Nav.NavigateTo("/admin/ui-dashboards");

    // ── Assistant Machine logic ──
    private async Task OpenAssistant()
    {
        _assistantStep = 1;
        _assistantMode = 0;
        _asstSelectedSingle = "";
        _asstSelectedGroup = new();
        _asstGroupName = "";
        _asstCommonTags = new();
        _asstSelectedTags = new();
        _asstTagSearch = "";
        _asstShowSelectedOnly = false;
        _asstError = null;
        _asstGenerating = false;
        if (_asstMachines is null)
        {
            try { _asstMachines = await Api.GetMachinesAsync() ?? []; }
            catch { _asstMachines = []; }
        }
    }

    private void CloseAssistant() { _assistantStep = 0; _asstError = null; }

    private bool CanGoNext() => _assistantStep switch
    {
        1 => true,
        2 => _assistantMode == 0 ? !string.IsNullOrWhiteSpace(_asstSelectedSingle)
                                 : _asstSelectedGroup.Count > 0,
        3 => _asstSelectedTags.Count > 0,
        _ => false
    };

    private async Task AssistantNext()
    {
        if (_assistantStep == 2)
        {
            // Charger les tags communs
            _asstTagsLoading = true;
            _asstCommonTags = new();
            _asstSelectedTags = new();
            _assistantStep = 3;
            StateHasChanged();

            try
            {
                var machines = _assistantMode == 0
                    ? new List<string> { _asstSelectedSingle }
                    : _asstSelectedGroup.ToList();

                // Charger tags pour chaque machine
                List<List<TagMappingDto>> allTagLists = new();
                foreach (var mc in machines)
                {
                    var tags = await Api.GetMachineTagsAsync(mc) ?? [];
                    allTagLists.Add(tags);
                }

                // Union de tous les tags disponibles sur au moins une machine
                Dictionary<string, TagMappingDto> uniqueTags = new();
                foreach (var tagList in allTagLists)
                {
                    foreach (var tag in tagList)
                    {
                        if (!uniqueTags.ContainsKey(tag.OpcNodeId))
                            uniqueTags[tag.OpcNodeId] = tag;
                    }
                }
                _asstCommonTags = uniqueTags.Values.OrderBy(t => t.OpcNodeId).ToList();
            }
            catch (Exception ex) { Error = ex.Message; }
            finally { _asstTagsLoading = false; }
        }
        else
        {
            _assistantStep++;
        }
    }

    private void AssistantBack()
    {
        _assistantStep--;
        _asstError = null;
    }

    private void ToggleMachineGroup(string mc, bool add)
    {
        if (add) _asstSelectedGroup.Add(mc);
        else _asstSelectedGroup.Remove(mc);
    }

    private void ToggleTag(string nodeId, bool add)
    {
        if (add) _asstSelectedTags[nodeId] = SuggestRole(nodeId);
        else _asstSelectedTags.Remove(nodeId);
    }

    private void SetTagRole(string nodeId, string role)
    {
        if (_asstSelectedTags.ContainsKey(nodeId))
            _asstSelectedTags[nodeId] = role;
    }

    private static string SuggestRole(string nodeId)
    {
        var n = nodeId.ToLowerInvariant();
        if (n.Contains("status") || n.Contains("etat") || n.Contains("state")) return "Status";
        if (n.Contains("count") || n.Contains("counter") || n.Contains("compteur")) return "Counter";
        return "Value";
    }

    private async Task GenerateAsync()
    {
        _asstGenerating = true;
        _asstError = null;
        StateHasChanged();
        try
        {
            var machines = _assistantMode == 0
                ? new List<string> { _asstSelectedSingle }
                : _asstSelectedGroup.ToList();

            int orderIdx = Zones?.Count ?? 0;
            foreach (var mc in machines)
            {
                // 1. Créer la zone
                var zoneName = _assistantMode == 1 && !string.IsNullOrWhiteSpace(_asstGroupName)
                    ? $"{_asstGroupName} – {mc}"
                    : mc;
                var zone = await Api.CreateZoneAsync(DashboardId, new UiZoneCreateDto
                {
                    Title = zoneName,
                    LayoutType = "Grid",
                    PropsJson = $"{{\"columns\":{_asstSelectedTags.Count}}}",
                    OrderIndex = orderIdx++
                });
                if (zone is null) continue;

                // 2. Pour chaque tag coché : créer widget + binding
                int wIdx = 0;
                foreach (var kv in _asstSelectedTags)
                {
                    var label = kv.Key.Split('.', '/').LastOrDefault() ?? kv.Key;
                    var widget = await Api.CreateWidgetAsync(zone.Id, new UiWidgetCreateDto
                    {
                        Title = label,
                        WidgetType = kv.Value,  // Role = WidgetType (Status/Counter/Value)
                        OrderIndex = wIdx++
                    });
                    if (widget is null) continue;

                    await Api.CreateBindingAsync(widget.Id, new UiWidgetBindingCreateDto
                    {
                        MachineCode = mc,
                        OpcNodeId = kv.Key,
                        BindingRole = kv.Value
                    });
                }
            }

            CloseAssistant();
            await LoadZones();
        }
        catch (Exception ex)
        {
            _asstError = ex.Message;
        }
        finally { _asstGenerating = false; }
    }

    private async Task LoadZones()
    {
        Error = null; Zones = null;
        SelectedZoneId = Guid.Empty; SelectedWidgetId = Guid.Empty;
        Widgets = null; Bindings = null;
        try { Zones = await Api.GetZonesAsync(DashboardId) ?? []; }
        catch (Exception ex) { Error = ex.Message; Zones = []; }
    }

    private void NewZone() { ZoneEditId = Guid.Empty; ZoneForm = new UiZoneCreateDto(); }
    private void EditZone(UiZoneDto z) { ZoneEditId = z.Id; ZoneForm = new UiZoneCreateDto { Title = z.Title, LayoutType = z.LayoutType, PropsJson = z.PropsJson, OrderIndex = z.OrderIndex }; }
    private void CloseZone() => ZoneForm = null;

    private async Task SaveZone()
    {
        if (ZoneForm is null) return;
        try
        {
            if (ZoneEditId == Guid.Empty)
                await Api.CreateZoneAsync(DashboardId, ZoneForm);
            else
                await Api.UpdateZoneAsync(ZoneEditId, new UiZoneUpdateDto { Title = ZoneForm.Title, LayoutType = ZoneForm.LayoutType, PropsJson = ZoneForm.PropsJson, OrderIndex = ZoneForm.OrderIndex });
            CloseZone(); await LoadZones();
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task DeleteZone(Guid id)
    {
        try { await Api.DeleteZoneAsync(id); await LoadZones(); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task SelectZone(Guid zoneId)
    {
        SelectedZoneId = zoneId; SelectedWidgetId = Guid.Empty; Bindings = null;
        try { Widgets = await Api.GetWidgetsAsync(zoneId) ?? []; }
        catch (Exception ex) { Error = ex.Message; Widgets = []; }
    }

    private void NewWidget() { if (SelectedZoneId == Guid.Empty) return; WidgetEditId = Guid.Empty; WidgetForm = new UiWidgetCreateDto(); }
    private void EditWidget(UiWidgetDto w) { WidgetEditId = w.Id; WidgetForm = new UiWidgetCreateDto { Title = w.Title, WidgetType = w.WidgetType, PropsJson = w.PropsJson, OrderIndex = w.OrderIndex }; }
    private void CloseWidget() => WidgetForm = null;

    private async Task SaveWidget()
    {
        if (WidgetForm is null) return;
        if (SelectedZoneId == Guid.Empty) { Error = "Sélectionne une zone."; return; }
        try
        {
            if (WidgetEditId == Guid.Empty)
                await Api.CreateWidgetAsync(SelectedZoneId, WidgetForm);
            else
                await Api.UpdateWidgetAsync(WidgetEditId, new UiWidgetUpdateDto { Title = WidgetForm.Title, WidgetType = WidgetForm.WidgetType, PropsJson = WidgetForm.PropsJson, OrderIndex = WidgetForm.OrderIndex });
            CloseWidget(); await SelectZone(SelectedZoneId);
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task DeleteWidget(Guid id)
    {
        try { await Api.DeleteWidgetAsync(id); await SelectZone(SelectedZoneId); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task SelectWidget(Guid widgetId)
    {
        SelectedWidgetId = widgetId;
        try { Bindings = await Api.GetBindingsAsync(widgetId) ?? []; }
        catch (Exception ex) { Error = ex.Message; Bindings = []; }
    }

    private void NewBinding() { if (SelectedWidgetId == Guid.Empty) return; BindingEditId = Guid.Empty; BindingForm = new UiWidgetBindingCreateDto(); }
    private void EditBinding(UiWidgetBindingDto b) { BindingEditId = b.Id; BindingForm = new UiWidgetBindingCreateDto { MachineCode = b.MachineCode, OpcNodeId = b.OpcNodeId, BindingRole = b.BindingRole }; }
    private void CloseBinding() => BindingForm = null;

    private async Task SaveBinding()
    {
        if (BindingForm is null) return;
        if (SelectedWidgetId == Guid.Empty) { Error = "Sélectionne un widget."; return; }
        try
        {
            if (BindingEditId == Guid.Empty)
                await Api.CreateBindingAsync(SelectedWidgetId, BindingForm);
            else
                await Api.UpdateBindingAsync(BindingEditId, new UiWidgetBindingUpdateDto { MachineCode = BindingForm.MachineCode, OpcNodeId = BindingForm.OpcNodeId, BindingRole = BindingForm.BindingRole });
            CloseBinding(); await SelectWidget(SelectedWidgetId);
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private void SelectAllFilteredTags()
    {
        var filteredTags = _asstCommonTags
            .Where(t => string.IsNullOrEmpty(_asstTagSearch) || t.OpcNodeId.Contains(_asstTagSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();
        foreach (var tag in filteredTags)
        {
            if (!_asstSelectedTags.ContainsKey(tag.OpcNodeId))
            {
                _asstSelectedTags[tag.OpcNodeId] = "Value";
            }
        }
    }

    private void DeselectAllFilteredTags()
    {
        var filteredTags = _asstCommonTags
            .Where(t => string.IsNullOrEmpty(_asstTagSearch) || t.OpcNodeId.Contains(_asstTagSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();
        foreach (var tag in filteredTags)
        {
            _asstSelectedTags.Remove(tag.OpcNodeId);
        }
    }

    private async Task DeleteBinding(Guid id)
    {
        try { await Api.DeleteBindingAsync(id); await SelectWidget(SelectedWidgetId); }
        catch (Exception ex) { Error = ex.Message; }
    }
}
