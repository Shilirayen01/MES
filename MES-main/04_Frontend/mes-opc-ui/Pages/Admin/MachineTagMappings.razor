@page "/admin/machines/{MachineCode}/tag-mappings"
@using mes_opc_ui.Services.AdminApi
@using Microsoft.AspNetCore.Components.Forms
@inject TagMappingsApiClient Api
@inject NavigationManager Nav

<style>
    .tm-page {
        --white:       #ffffff;
        --bg-soft:     #f8fafc;
        --border:      #e8edf5;
        --border-soft: #f1f5f9;
        --accent:      #1e40af;
        --accent-dim:  rgba(30,64,175,0.07);
        --green-bg:    #d1fae5;
        --green-txt:   #065f46;
        --green-bdr:   #a7f3d0;
        --tag-bg:      #dbeafe;
        --tag-txt:     #1e40af;
        --tag-bdr:     #bfdbfe;
        --pink:        #be185d;
        --orange:      #d97706;
        --orange-bg:   #fffbeb;
        --orange-bdr:  #fde68a;
        --orange-txt:  #92400e;
        --red:         #dc2626;
        --red-bg:      rgba(220,38,38,0.07);
        --red-bdr:     #fecaca;
        --text-900:    #0f172a;
        --text-navy:   #1e4d7b;
        --text-muted:  #64748b;
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text-900);
    }

    /* ── Header ── */
    .tm-page .page-header {
        display: flex; align-items: flex-end; justify-content: space-between;
        margin-bottom: 28px; padding-bottom: 18px; border-bottom: 1px solid var(--border);
    }
    .tm-page .page-header h3 {
        font-size: 24px; font-weight: 800; letter-spacing: -0.5px;
        color: var(--text-900); margin: 0 0 5px 0;
        display: flex; align-items: center; gap: 10px;
    }
    .tm-page .page-header p { font-size: 13px; color: var(--text-navy); margin: 0; }
    .tm-page .header-machine {
        font-family: 'JetBrains Mono', monospace; font-size: 14px; font-weight: 700;
        color: var(--accent); background: var(--tag-bg);
        border: 1px solid var(--tag-bdr); padding: 2px 10px; border-radius: 6px;
    }

    /* ── Toolbar ── */
    .tm-page .toolbar {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 20px;
    }
    .tm-page .toolbar-sep { width: 1px; height: 22px; background: var(--border); }

    /* ── Buttons ── */
    .tm-page .tm-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; border: 1px solid transparent;
        font-family: inherit; line-height: 1.4;
    }
    .tm-page .tm-btn-primary {
        background: var(--accent); color: #fff; border-color: var(--accent);
    }
    .tm-page .tm-btn-primary:hover {
        background: #1e3a8a; box-shadow: 0 4px 14px rgba(30,64,175,0.25); transform: translateY(-1px);
    }
    .tm-page .tm-btn-ghost {
        background: var(--white); color: var(--text-muted); border-color: var(--border);
    }
    .tm-page .tm-btn-ghost:hover {
        color: var(--text-900); border-color: #c8d2e0; background: var(--bg-soft);
    }
    .tm-page .tm-btn-sm { font-size: 11px; padding: 4px 10px; border-radius: 6px; }
    .tm-page .tm-btn-outline {
        background: var(--accent-dim); color: var(--accent); border-color: var(--tag-bdr);
    }
    .tm-page .tm-btn-outline:hover { background: var(--tag-bg); }
    .tm-page .tm-btn-warn {
        background: var(--orange-bg); color: var(--orange-txt); border-color: var(--orange-bdr);
    }
    .tm-page .tm-btn-warn:hover { background: #fef3c7; }

    /* ── Alert ── */
    .tm-page .tm-alert-danger {
        background: var(--red-bg); border: 1px solid var(--red-bdr);
        color: var(--red); border-radius: 10px; padding: 12px 16px;
        font-size: 13px; margin-bottom: 16px;
    }
    .tm-page .loading-text { color: var(--text-navy); font-size: 13px; }

    /* ── Table Card ── */
    .tm-page .table-card {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 14px; overflow: hidden; margin-bottom: 24px;
        box-shadow: 0 1px 4px rgba(15,23,42,0.05);
    }
    .tm-page .table-scroll { overflow-x: auto; }
    .tm-page .table-scroll::-webkit-scrollbar { height: 4px; }
    .tm-page .table-scroll::-webkit-scrollbar-track { background: var(--bg-soft); }
    .tm-page .table-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .tm-page .tm-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .tm-page .tm-table th {
        text-align: left; padding: 10px 14px; white-space: nowrap;
        color: var(--text-navy); font-size: 10px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.5px;
        border: 1px solid #1e3a5f; background: var(--bg-soft);
    }
    .tm-page .tm-table td {
        padding: 11px 14px; color: var(--text-900);
        border: 1px solid #1e3a5f; vertical-align: middle;
        white-space: normal; word-break: break-word;
    }
    .tm-page .tm-table tbody tr:hover td { background: #eff6ff; }

    .tm-page .cell-id {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        color: var(--text-muted); font-weight: 600;
    }
    .tm-page .cell-nodeid {
        font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--accent);
        white-space: normal; word-break: break-all; display: block;
    }
    .tm-page .cell-char { font-size: 12px; color: var(--pink); font-weight: 700; }
    .tm-page .cell-type {
        font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-navy);
    }
    .tm-page .cell-num {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        color: var(--text-navy); text-align: right; display: block;
    }
    .tm-page .badge-active {
        display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px;
        border-radius: 6px; background: var(--green-bg); border: 1px solid var(--green-bdr);
        color: var(--green-txt); font-size: 10px; font-weight: 700; text-transform: uppercase;
    }
    .tm-page .badge-active::before {
        content: ''; width: 5px; height: 5px; border-radius: 50%;
        background: var(--green-txt); animation: tmPulse 2s ease infinite;
    }
    .tm-page .badge-inactive {
        display: inline-flex; padding: 3px 9px; border-radius: 6px;
        background: var(--bg-soft); border: 1px solid var(--border);
        color: var(--text-muted); font-size: 10px; font-weight: 700; text-transform: uppercase;
    }
    @@keyframes tmPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    .tm-page .cell-actions { display: flex; gap: 6px; white-space: nowrap; }

    /* ── Form Panel ── */
    .tm-page .form-panel {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 14px; overflow: hidden; margin-bottom: 24px;
        box-shadow: 0 1px 4px rgba(15,23,42,0.05);
        border-top: 3px solid var(--accent);
        animation: tmFadeUp 0.25s ease;
    }
    @@keyframes tmFadeUp { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

    .tm-page .form-panel-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px; border-bottom: 1px solid var(--border); background: var(--bg-soft);
    }
    .tm-page .form-panel-title {
        font-size: 14px; font-weight: 700; color: var(--text-900);
        display: flex; align-items: center; gap: 8px;
    }
    .tm-page .form-panel-title .edit-id {
        font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--accent);
        background: var(--tag-bg); border: 1px solid var(--tag-bdr); padding: 1px 7px; border-radius: 5px;
    }

    .tm-page .form-panel-body {
        padding: 20px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 14px 16px;
    }
    .tm-page .form-section-label {
        font-size: 11px; font-weight: 700; color: var(--accent);
        text-transform: uppercase; letter-spacing: 0.6px;
        grid-column: 1 / -1; padding-bottom: 6px;
        position: relative; margin-top: 6px;
        display: flex; align-items: center; gap: 8px;
    }
    .tm-page .form-section-label::after {
        content: ''; flex: 1; height: 1px; background: var(--border);
    }
    .tm-page .form-group { display: flex; flex-direction: column; gap: 5px; }
    .tm-page .form-group label {
        font-size: 11px; color: var(--text-navy); font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.5px;
    }
    .tm-page .form-group.full-width { grid-column: 1 / -1; }
    .tm-page .tm-input {
        background: var(--bg-soft); border: 1.5px solid var(--border);
        color: var(--text-900); border-radius: 8px; padding: 8px 10px;
        font-size: 13px; font-family: inherit; width: 100%; transition: border-color 0.15s;
    }
    .tm-page .tm-input.mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; }
    .tm-page .tm-input:focus {
        outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim);
    }
    .tm-page .form-check-row { display: flex; align-items: center; gap: 8px; padding-top: 22px; }
    .tm-page .form-check-row input[type="checkbox"] {
        accent-color: var(--accent); width: 15px; height: 15px; cursor: pointer;
    }
    .tm-page .form-check-row label { font-size: 13px; color: var(--text-900); cursor: pointer; }
    .tm-page .form-panel-footer {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 20px; border-top: 1px solid var(--border); background: var(--bg-soft);
    }
    .tm-page .validation-errors {
        background: var(--red-bg); border: 1px solid var(--red-bdr);
        border-radius: 8px; padding: 8px 12px; font-size: 12px;
        color: var(--red); grid-column: 1 / -1;
    }
</style>

<div class="tm-page">

    <div class="page-header">
        <div>
            <h3>Tag Mappings <span class="header-machine">@MachineCode</span></h3>
            <p>Configuration des tags OPC-UA pour cette machine</p>
        </div>
    </div>

    <div class="toolbar">
        <button class="tm-btn tm-btn-primary" @onclick="New">+ Nouveau Mapping</button>
        <div class="toolbar-sep"></div>
        <button class="tm-btn tm-btn-ghost" @onclick="Back">← Retour Machines</button>
        <button class="tm-btn tm-btn-ghost" @onclick="Load">Rafraîchir</button>
    </div>

    @if (Error is not null)
    {
        <div class="tm-alert-danger">@Error</div>
    }

    @if (Items is null)
    {
        <p class="loading-text">Chargement...</p>
    }
    else
    {
        <div class="table-card">
            <div class="table-scroll">
                <table class="tm-table">
                    <thead>
                        <tr>
                            <th style="width:50px;">Id</th>
                            <th>OPC Node Id</th>
                            <th>Caractéristique</th>
                            <th>Type</th>
                            <th style="text-align:right;">Sampling</th>
                            <th style="text-align:right;">Publishing</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Items)
                        {
                            <tr>
                                <td><span class="cell-id">#@t.Id</span></td>
                                <td><span class="cell-nodeid" title="@t.OpcNodeId">@t.OpcNodeId</span></td>
                                <td><span class="cell-char">@t.CharacteristicCode</span></td>
                                <td><span class="cell-type">@t.DataTypeExpected</span></td>
                                <td><span class="cell-num">@(t.SamplingMs.HasValue ? $"{t.SamplingMs} ms" : "—")</span></td>
                                <td><span class="cell-num">@(t.PublishingMs.HasValue ? $"{t.PublishingMs} ms" : "—")</span></td>
                                <td>
                                    @if (t.IsActive) { <span class="badge-active">Actif</span> }
                                    else             { <span class="badge-inactive">Inactif</span> }
                                </td>
                                <td>
                                    <div class="cell-actions">
                                        <button class="tm-btn tm-btn-outline tm-btn-sm" @onclick="() => Edit(t)">Edit</button>
                                        <button class="tm-btn tm-btn-warn tm-btn-sm" @onclick="() => Deactivate(t)">Désactiver</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* ── Form: Créer ── *@
    @if (CreateForm is not null)
    {
        <div class="form-panel">
            <div class="form-panel-header">
                <div class="form-panel-title">+ Créer Mapping</div>
                <button class="tm-btn tm-btn-ghost tm-btn-sm" @onclick="Cancel">Fermer</button>
            </div>
            <EditForm Model="CreateForm" OnValidSubmit="SaveCreate">
                <DataAnnotationsValidator />
                <div class="form-panel-body">
                    <ValidationSummary class="validation-errors" />
                    <div class="form-section-label">Identification</div>
                    <div class="form-group full-width">
                        <label>OPC Node Id</label>
                        <InputText class="tm-input mono" @bind-Value="CreateForm.OpcNodeId" placeholder="ns=2;i=1001" />
                    </div>
                    <div class="form-group">
                        <label>Characteristic Code</label>
                        <InputText class="tm-input" @bind-Value="CreateForm.CharacteristicCode" placeholder="TEMP_01" />
                    </div>
                    <div class="form-group">
                        <label>Data Type</label>
                        <InputText class="tm-input" @bind-Value="CreateForm.DataTypeExpected" placeholder="Double, Int32…" />
                    </div>
                    <div class="form-group">
                        <label>Unité</label>
                        <InputText class="tm-input" @bind-Value="CreateForm.Unit" placeholder="°C, bar…" />
                    </div>
                    <div class="form-section-label">Plage de valeurs</div>
                    <div class="form-group">
                        <label>Min Value</label>
                        <InputNumber class="tm-input" TValue="double?" @bind-Value="CreateForm.MinValue" placeholder="0" />
                    </div>
                    <div class="form-group">
                        <label>Max Value</label>
                        <InputNumber class="tm-input" TValue="double?" @bind-Value="CreateForm.MaxValue" placeholder="100" />
                    </div>
                    <div class="form-section-label">Timing OPC-UA</div>
                    <div class="form-group">
                        <label>Sampling (ms)</label>
                        <InputNumber class="tm-input" TValue="int?" @bind-Value="CreateForm.SamplingMs" placeholder="500" />
                    </div>
                    <div class="form-group">
                        <label>Publishing (ms)</label>
                        <InputNumber class="tm-input" TValue="int?" @bind-Value="CreateForm.PublishingMs" placeholder="1000" />
                    </div>
                    <div class="form-check-row">
                        <InputCheckbox @bind-Value="CreateForm.IsActive" id="createActive" />
                        <label for="createActive">Mapping actif</label>
                    </div>
                </div>
                <div class="form-panel-footer">
                    <button type="submit" class="tm-btn tm-btn-primary">Enregistrer</button>
                    <button type="button" class="tm-btn tm-btn-ghost" @onclick="Cancel">Annuler</button>
                </div>
            </EditForm>
        </div>
    }

    @* ── Form: Modifier ── *@
    @if (UpdateForm is not null)
    {
        <div class="form-panel">
            <div class="form-panel-header">
                <div class="form-panel-title">
                    Modifier Mapping <span class="edit-id">#@EditId</span>
                </div>
                <button class="tm-btn tm-btn-ghost tm-btn-sm" @onclick="Cancel">Fermer</button>
            </div>
            <EditForm Model="UpdateForm" OnValidSubmit="SaveUpdate">
                <DataAnnotationsValidator />
                <div class="form-panel-body">
                    <ValidationSummary class="validation-errors" />
                    <div class="form-section-label">Identification</div>
                    <div class="form-group full-width">
                        <label>OPC Node Id</label>
                        <InputText class="tm-input mono" @bind-Value="UpdateForm.OpcNodeId" />
                    </div>
                    <div class="form-group">
                        <label>Characteristic Code</label>
                        <InputText class="tm-input" @bind-Value="UpdateForm.CharacteristicCode" />
                    </div>
                    <div class="form-group">
                        <label>Data Type</label>
                        <InputText class="tm-input" @bind-Value="UpdateForm.DataTypeExpected" />
                    </div>
                    <div class="form-group">
                        <label>Unité</label>
                        <InputText class="tm-input" @bind-Value="UpdateForm.Unit" />
                    </div>
                    <div class="form-section-label">Plage de valeurs</div>
                    <div class="form-group">
                        <label>Min Value</label>
                        <InputNumber class="tm-input" TValue="double?" @bind-Value="UpdateForm.MinValue" />
                    </div>
                    <div class="form-group">
                        <label>Max Value</label>
                        <InputNumber class="tm-input" TValue="double?" @bind-Value="UpdateForm.MaxValue" />
                    </div>
                    <div class="form-section-label">Timing OPC-UA</div>
                    <div class="form-group">
                        <label>Sampling (ms)</label>
                        <InputNumber class="tm-input" TValue="int?" @bind-Value="UpdateForm.SamplingMs" />
                    </div>
                    <div class="form-group">
                        <label>Publishing (ms)</label>
                        <InputNumber class="tm-input" TValue="int?" @bind-Value="UpdateForm.PublishingMs" />
                    </div>
                    <div class="form-check-row">
                        <InputCheckbox @bind-Value="UpdateForm.IsActive" id="updateActive" />
                        <label for="updateActive">Mapping actif</label>
                    </div>
                </div>
                <div class="form-panel-footer">
                    <button type="submit" class="tm-btn tm-btn-primary">Enregistrer</button>
                    <button type="button" class="tm-btn tm-btn-ghost" @onclick="Cancel">Annuler</button>
                </div>
            </EditForm>
        </div>
    }

</div>

@code {
    [Parameter] public string MachineCode { get; set; } = "";

    private List<MachineTagMappingDto>? Items;
    private string? Error;

    private MachineTagMappingCreateDto? CreateForm;
    private MachineTagMappingUpdateDto? UpdateForm;
    private int EditId;

    protected override async Task OnParametersSetAsync() => await Load();

    private async Task Load()
    {
        Error = null; Items = null; StateHasChanged();
        try { Items = await Api.GetByMachineAsync(MachineCode) ?? []; }
        catch (Exception ex) { Error = ex.Message; Items = []; }
    }

    private void New() { UpdateForm = null; EditId = 0; CreateForm = new MachineTagMappingCreateDto { IsActive = true }; }

    private void Edit(MachineTagMappingDto t)
    {
        CreateForm = null; EditId = t.Id;
        UpdateForm = new MachineTagMappingUpdateDto
        {
            OpcNodeId = t.OpcNodeId, CharacteristicCode = t.CharacteristicCode,
            DataTypeExpected = t.DataTypeExpected, Unit = t.Unit,
            MinValue = t.MinValue, MaxValue = t.MaxValue,
            SamplingMs = t.SamplingMs, PublishingMs = t.PublishingMs, IsActive = t.IsActive
        };
    }

    private async Task Deactivate(MachineTagMappingDto t)
    {
        try { await Api.DeleteAsync(t.Id); await Load(); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task SaveCreate()
    {
        if (CreateForm is null) return;
        try { await Api.CreateAsync(MachineCode, CreateForm); CreateForm = null; await Load(); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task SaveUpdate()
    {
        if (UpdateForm is null) return;
        try { await Api.UpdateAsync(EditId, UpdateForm); UpdateForm = null; EditId = 0; await Load(); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private void Cancel() { CreateForm = null; UpdateForm = null; EditId = 0; }
    private void Back() => Nav.NavigateTo("/admin/machines");
}
