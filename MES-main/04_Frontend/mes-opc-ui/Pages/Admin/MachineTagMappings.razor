@page "/admin/machines/{MachineCode}/tag-mappings"
@using mes_opc_ui.Services.AdminApi
@using Microsoft.AspNetCore.Components.Forms
@inject TagMappingsApiClient Api
@inject NavigationManager Nav

<style>
    .tm-page {
        --bg-card:         #161b22;
        --bg-elevated:     #1c2128;
        --border:          #21262d;
        --border-bright:   #30363d;
        --accent-blue:     #238be6;
        --accent-blue-dim: rgba(35, 139, 230, 0.15);
        --green-badge-bg:  #1f8a5e;
        --tag-bg:          #122535;
        --tag-txt:         #58c4dc;
        --tag-border:      #1d4a65;
        --scope-pink:      #e879a0;
        --red:             #da3633;
        --red-dim:         rgba(218, 54, 51, 0.15);
        --orange:          #d97706;
        --orange-dim:      rgba(217,119,6,0.12);
        --text-primary:    #e6edf3;
        --text-secondary:  #7d8590;
        --text-muted:      #3d444d;
        font-family: 'DM Sans', sans-serif;
        color: var(--text-primary);
    }
    .tm-page .page-header {
        display: flex; align-items: flex-end; justify-content: space-between;
        margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid var(--border); position: relative;
    }
    .tm-page .page-header::after {
        content: ''; position: absolute; bottom: -1px; left: 0;
        width: 120px; height: 1px; background: linear-gradient(90deg, var(--accent-blue), transparent);
    }
    .tm-page .page-header h3 { font-size: 22px; font-weight: 600; letter-spacing: -0.3px; margin: 0 0 4px 0; display: flex; align-items: center; gap: 10px; }
    .tm-page .page-header p { font-size: 12px; color: var(--text-secondary); margin: 0; }
    .tm-page .header-machine {
        font-family: 'JetBrains Mono', monospace; font-size: 14px; font-weight: 700;
        color: var(--tag-txt); background: var(--tag-bg); border: 1px solid var(--tag-border);
        padding: 2px 10px; border-radius: 5px;
    }
    .tm-page .toolbar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }
    .tm-page .toolbar-sep { width: 1px; height: 24px; background: var(--border-bright); }
    .tm-page .tm-btn {
        display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px;
        border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer;
        transition: all 0.18s ease; border: 1px solid transparent; font-family: inherit; line-height: 1.4;
    }
    .tm-page .tm-btn-primary { background: var(--accent-blue); color: #fff; border-color: var(--accent-blue); }
    .tm-page .tm-btn-primary:hover { background: #3a9ef5; box-shadow: 0 0 14px rgba(35,139,230,0.35); transform: translateY(-1px); }
    .tm-page .tm-btn-ghost { background: transparent; color: var(--text-secondary); border-color: var(--border-bright); }
    .tm-page .tm-btn-ghost:hover { color: var(--text-primary); border-color: var(--accent-blue); background: var(--accent-blue-dim); }
    .tm-page .tm-btn-sm { font-size: 11px; padding: 3px 10px; }
    .tm-page .tm-btn-outline { background: transparent; color: var(--accent-blue); border-color: var(--accent-blue); }
    .tm-page .tm-btn-outline:hover { background: var(--accent-blue-dim); }
    .tm-page .tm-btn-warn { background: transparent; color: var(--orange); border-color: var(--orange); }
    .tm-page .tm-btn-warn:hover { background: var(--orange-dim); }
    .tm-page .tm-alert-danger {
        background: rgba(218,54,51,0.1); border: 1px solid rgba(218,54,51,0.3);
        color: #f87171; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px;
    }
    .tm-page .loading-text { color: var(--text-secondary); font-size: 13px; }
    .tm-page .table-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 24px; }
    .tm-page .table-scroll { overflow-x: auto; }
    .tm-page .tm-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .tm-page .tm-table th {
        text-align: left; padding: 10px 14px; white-space: nowrap;
        color: var(--text-secondary); font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.4px;
        border-bottom: 1px solid var(--border); background: var(--bg-elevated);
    }
    .tm-page .tm-table td { padding: 10px 14px; color: var(--text-primary); border-bottom: 1px solid var(--border); vertical-align: middle; }
    .tm-page .tm-table tbody tr:last-child td { border-bottom: none; }
    .tm-page .tm-table tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .tm-page .cell-id { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-muted); font-weight: 600; }
    .tm-page .cell-nodeid { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--tag-txt); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; }
    .tm-page .cell-char { font-size: 12px; color: var(--scope-pink); font-weight: 600; }
    .tm-page .cell-type { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-secondary); }
    .tm-page .cell-num { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-secondary); text-align: right; display: block; }
    .tm-page .badge-active { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 4px; background: var(--green-badge-bg); color: #fff; font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700; text-transform: uppercase; }
    .tm-page .badge-active::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,0.5); animation: tmPulse 2s ease infinite; }
    .tm-page .badge-inactive { display: inline-flex; padding: 2px 8px; border-radius: 4px; background: rgba(125,133,144,0.1); border: 1px solid var(--border-bright); color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700; text-transform: uppercase; }
    @@keyframes tmPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    .tm-page .cell-actions { display: flex; gap: 6px; white-space: nowrap; }
    .tm-page .form-panel { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 24px; animation: tmFadeUp 0.25s ease; }
    @@keyframes tmFadeUp { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .tm-page .form-panel-header { display: flex; align-items: center; justify-content: space-between; padding: 13px 20px; border-bottom: 1px solid var(--border); background: var(--bg-elevated); }
    .tm-page .form-panel-title { font-size: 14px; font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: 8px; }
    .tm-page .form-panel-title .edit-id { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--tag-txt); background: var(--tag-bg); border: 1px solid var(--tag-border); padding: 1px 7px; border-radius: 4px; }
    .tm-page .form-panel-body { padding: 20px; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 14px 16px; }
    .tm-page .form-section-label { font-size: 10px; font-weight: 700; color: var(--accent-blue); text-transform: uppercase; letter-spacing: 0.8px; grid-column: 1 / -1; padding-bottom: 6px; position: relative; margin-top: 4px; }
    .tm-page .form-section-label::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, var(--accent-blue), transparent); }
    .tm-page .form-group { display: flex; flex-direction: column; gap: 5px; }
    .tm-page .form-group label { font-size: 11px; color: var(--text-secondary); font-weight: 500; text-transform: uppercase; letter-spacing: 0.4px; }
    .tm-page .form-group.full-width { grid-column: 1 / -1; }
    .tm-page .tm-input { background: var(--bg-elevated); border: 1px solid var(--border-bright); color: var(--text-primary); border-radius: 6px; padding: 7px 10px; font-size: 13px; font-family: inherit; width: 100%; transition: border-color 0.15s; }
    .tm-page .tm-input.mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; }
    .tm-page .tm-input:focus { outline: none; border-color: var(--accent-blue); box-shadow: 0 0 0 2px var(--accent-blue-dim); }
    .tm-page .form-check-row { display: flex; align-items: center; gap: 8px; padding-top: 22px; }
    .tm-page .form-check-row input[type="checkbox"] { accent-color: var(--accent-blue); width: 15px; height: 15px; cursor: pointer; }
    .tm-page .form-check-row label { font-size: 13px; color: var(--text-primary); cursor: pointer; }
    .tm-page .form-panel-footer { display: flex; align-items: center; gap: 10px; padding: 14px 20px; border-top: 1px solid var(--border); }
    .tm-page .validation-errors { background: var(--red-dim); border: 1px solid rgba(218,54,51,0.3); border-radius: 6px; padding: 8px 12px; font-size: 12px; color: #f87171; grid-column: 1 / -1; }
</style>

<div class="tm-page">

    <div class="page-header">
        <div>
            <h3>Tag Mappings <span class="header-machine">@MachineCode</span></h3>
            <p>Configuration des tags OPC-UA pour cette machine</p>
        </div>
    </div>

    <div class="toolbar">
        <button class="tm-btn tm-btn-primary" @onclick="New">+ Nouveau Mapping</button>
        <div class="toolbar-sep"></div>
        <button class="tm-btn tm-btn-ghost" @onclick="Back">← Retour Machines</button>
        <button class="tm-btn tm-btn-ghost" @onclick="Load">↻ Rafraîchir</button>
    </div>

    @if (Error is not null)
    {
        <div class="tm-alert-danger">@Error</div>
    }

    @if (Items is null)
    {
        <p class="loading-text">Chargement...</p>
    }
    else
    {
        <div class="table-card">
            <div class="table-scroll">
                <table class="tm-table">
                    <thead>
                        <tr>
                            <th style="width:50px;">Id</th>
                            <th>OPC Node Id</th>
                            <th>Caractéristique</th>
                            <th>Type</th>
                            <th style="text-align:right;">Sampling</th>
                            <th style="text-align:right;">Publishing</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Items)
                        {
                            <tr>
                                <td><span class="cell-id">#@t.Id</span></td>
                                <td><span class="cell-nodeid" title="@t.OpcNodeId">@t.OpcNodeId</span></td>
                                <td><span class="cell-char">@t.CharacteristicCode</span></td>
                                <td><span class="cell-type">@t.DataTypeExpected</span></td>
                                <td><span class="cell-num">@(t.SamplingMs.HasValue ? $"{t.SamplingMs} ms" : "—")</span></td>
                                <td><span class="cell-num">@(t.PublishingMs.HasValue ? $"{t.PublishingMs} ms" : "—")</span></td>
                                <td>
                                    @if (t.IsActive) { <span class="badge-active">Actif</span> }
                                    else             { <span class="badge-inactive">Inactif</span> }
                                </td>
                                <td>
                                    <div class="cell-actions">
                                        <button class="tm-btn tm-btn-outline tm-btn-sm" @onclick="() => Edit(t)">✏ Edit</button>
                                        <button class="tm-btn tm-btn-warn tm-btn-sm" @onclick="() => Deactivate(t)">Désactiver</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* ── Form: Créer ── *@
    @if (CreateForm is not null)
    {
        <div class="form-panel">
            <div class="form-panel-header">
                <div class="form-panel-title">+ Créer Mapping</div>
                <button class="tm-btn tm-btn-ghost tm-btn-sm" @onclick="Cancel">✕ Fermer</button>
            </div>
            <EditForm Model="CreateForm" OnValidSubmit="SaveCreate">
                <DataAnnotationsValidator />
                <div class="form-panel-body">
                    <ValidationSummary class="validation-errors" />
                    <div class="form-section-label">Identification</div>
                    <div class="form-group full-width">
                        <label>OPC Node Id</label>
                        <InputText class="tm-input mono" @bind-Value="CreateForm.OpcNodeId" placeholder="ns=2;i=1001" />
                    </div>
                    <div class="form-group">
                        <label>Characteristic Code</label>
                        <InputText class="tm-input" @bind-Value="CreateForm.CharacteristicCode" placeholder="TEMP_01" />
                    </div>
                    <div class="form-group">
                        <label>Data Type</label>
                        <InputText class="tm-input" @bind-Value="CreateForm.DataTypeExpected" placeholder="Double, Int32…" />
                    </div>
                    <div class="form-group">
                        <label>Unité</label>
                        <InputText class="tm-input" @bind-Value="CreateForm.Unit" placeholder="°C, bar…" />
                    </div>
                    <div class="form-section-label">Plage de valeurs</div>
                    <div class="form-group">
                        <label>Min Value</label>
                        <InputNumber class="tm-input" TValue="double?" @bind-Value="CreateForm.MinValue" placeholder="0" />
                    </div>
                    <div class="form-group">
                        <label>Max Value</label>
                        <InputNumber class="tm-input" TValue="double?" @bind-Value="CreateForm.MaxValue" placeholder="100" />
                    </div>
                    <div class="form-section-label">Timing OPC-UA</div>
                    <div class="form-group">
                        <label>Sampling (ms)</label>
                        <InputNumber class="tm-input" TValue="int?" @bind-Value="CreateForm.SamplingMs" placeholder="500" />
                    </div>
                    <div class="form-group">
                        <label>Publishing (ms)</label>
                        <InputNumber class="tm-input" TValue="int?" @bind-Value="CreateForm.PublishingMs" placeholder="1000" />
                    </div>
                    <div class="form-check-row">
                        <InputCheckbox @bind-Value="CreateForm.IsActive" id="createActive" />
                        <label for="createActive">Mapping actif</label>
                    </div>
                </div>
                <div class="form-panel-footer">
                    <button type="submit" class="tm-btn tm-btn-primary">Enregistrer</button>
                    <button type="button" class="tm-btn tm-btn-ghost" @onclick="Cancel">Annuler</button>
                </div>
            </EditForm>
        </div>
    }

    @* ── Form: Modifier ── *@
    @if (UpdateForm is not null)
    {
        <div class="form-panel">
            <div class="form-panel-header">
                <div class="form-panel-title">
                    ✏ Modifier Mapping <span class="edit-id">#@EditId</span>
                </div>
                <button class="tm-btn tm-btn-ghost tm-btn-sm" @onclick="Cancel">✕ Fermer</button>
            </div>
            <EditForm Model="UpdateForm" OnValidSubmit="SaveUpdate">
                <DataAnnotationsValidator />
                <div class="form-panel-body">
                    <ValidationSummary class="validation-errors" />
                    <div class="form-section-label">Identification</div>
                    <div class="form-group full-width">
                        <label>OPC Node Id</label>
                        <InputText class="tm-input mono" @bind-Value="UpdateForm.OpcNodeId" />
                    </div>
                    <div class="form-group">
                        <label>Characteristic Code</label>
                        <InputText class="tm-input" @bind-Value="UpdateForm.CharacteristicCode" />
                    </div>
                    <div class="form-group">
                        <label>Data Type</label>
                        <InputText class="tm-input" @bind-Value="UpdateForm.DataTypeExpected" />
                    </div>
                    <div class="form-group">
                        <label>Unité</label>
                        <InputText class="tm-input" @bind-Value="UpdateForm.Unit" />
                    </div>
                    <div class="form-section-label">Plage de valeurs</div>
                    <div class="form-group">
                        <label>Min Value</label>
                        <InputNumber class="tm-input" TValue="double?" @bind-Value="UpdateForm.MinValue" />
                    </div>
                    <div class="form-group">
                        <label>Max Value</label>
                        <InputNumber class="tm-input" TValue="double?" @bind-Value="UpdateForm.MaxValue" />
                    </div>
                    <div class="form-section-label">Timing OPC-UA</div>
                    <div class="form-group">
                        <label>Sampling (ms)</label>
                        <InputNumber class="tm-input" TValue="int?" @bind-Value="UpdateForm.SamplingMs" />
                    </div>
                    <div class="form-group">
                        <label>Publishing (ms)</label>
                        <InputNumber class="tm-input" TValue="int?" @bind-Value="UpdateForm.PublishingMs" />
                    </div>
                    <div class="form-check-row">
                        <InputCheckbox @bind-Value="UpdateForm.IsActive" id="updateActive" />
                        <label for="updateActive">Mapping actif</label>
                    </div>
                </div>
                <div class="form-panel-footer">
                    <button type="submit" class="tm-btn tm-btn-primary">Enregistrer</button>
                    <button type="button" class="tm-btn tm-btn-ghost" @onclick="Cancel">Annuler</button>
                </div>
            </EditForm>
        </div>
    }

</div>

@code {
    [Parameter] public string MachineCode { get; set; } = "";

    private List<MachineTagMappingDto>? Items;
    private string? Error;

    private MachineTagMappingCreateDto? CreateForm;
    private MachineTagMappingUpdateDto? UpdateForm;
    private int EditId;

    protected override async Task OnParametersSetAsync() => await Load();

    private async Task Load()
    {
        Error = null; Items = null; StateHasChanged();
        try { Items = await Api.GetByMachineAsync(MachineCode) ?? []; }
        catch (Exception ex) { Error = ex.Message; Items = []; }
    }

    private void New() { UpdateForm = null; EditId = 0; CreateForm = new MachineTagMappingCreateDto { IsActive = true }; }

    private void Edit(MachineTagMappingDto t)
    {
        CreateForm = null; EditId = t.Id;
        UpdateForm = new MachineTagMappingUpdateDto
        {
            OpcNodeId = t.OpcNodeId, CharacteristicCode = t.CharacteristicCode,
            DataTypeExpected = t.DataTypeExpected, Unit = t.Unit,
            MinValue = t.MinValue, MaxValue = t.MaxValue,
            SamplingMs = t.SamplingMs, PublishingMs = t.PublishingMs, IsActive = t.IsActive
        };
    }

    private async Task Deactivate(MachineTagMappingDto t)
    {
        try { await Api.DeleteAsync(t.Id); await Load(); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task SaveCreate()
    {
        if (CreateForm is null) return;
        try { await Api.CreateAsync(MachineCode, CreateForm); CreateForm = null; await Load(); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task SaveUpdate()
    {
        if (UpdateForm is null) return;
        try { await Api.UpdateAsync(EditId, UpdateForm); UpdateForm = null; EditId = 0; await Load(); }
        catch (Exception ex) { Error = ex.Message; }
    }

    private void Cancel() { CreateForm = null; UpdateForm = null; EditId = 0; }
    private void Back() => Nav.NavigateTo("/admin/machines");
}
