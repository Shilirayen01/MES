    private async Task Save()
    {
        if (_form is null || string.IsNullOrEmpty(_selectedMachine)) return;
        _error = null;
        try
        {
            if (_editId is null)
            {
                await CycleRulesApi.CreateAsync(_selectedMachine, _form);
                ActivityLog.LogAdd(
                    $"Cycle rule ajoutée",
                    "Cycle Rules",
                    $"Machine : {_selectedMachine} — Scope : {_form.ScopeKey}");
            }
            else
            {
                var upd = new CycleRuleUpdateDto
                {
                    ScopeKey = _form.ScopeKey, IsActive = _form.IsActive,
                    StartStrategy = _form.StartStrategy, StartNodeId = _form.StartNodeId,
                    StartEdgeType = _form.StartEdgeType, StartValue = _form.StartValue,
                    EndPrimaryStrategy = _form.EndPrimaryStrategy, EndPrimaryNodeId = _form.EndPrimaryNodeId,
                    EndPrimaryEdgeType = _form.EndPrimaryEdgeType,
                    EndFallbackStrategy = _form.EndFallbackStrategy, EndFallbackNodeId = _form.EndFallbackNodeId,
                    AbortNodeIds = _form.AbortNodeIds,
                    DebounceMs = _form.DebounceMs, MinCycleSeconds = _form.MinCycleSeconds, TimeoutSeconds = _form.TimeoutSeconds,
                    Epsilon = _form.Epsilon, TargetTolerance = _form.TargetTolerance,
                    ValidationSpeedNodeId = _form.ValidationSpeedNodeId, ValidationSpeedMin = _form.ValidationSpeedMin,
                    ValidationStateNodeId = _form.ValidationStateNodeId, ValidationStateValue = _form.ValidationStateValue,
                    RecoveryStrategy = _form.RecoveryStrategy, RecoveryConfirmNodeId = _form.RecoveryConfirmNodeId,
                    RecoveryConfirmDelta = _form.RecoveryConfirmDelta, RecoveryConfirmWindowSeconds = _form.RecoveryConfirmWindowSeconds
                };
                await CycleRulesApi.UpdateAsync(_selectedMachine, _editId.Value, upd);
                ActivityLog.LogModify(
                    $"Cycle rule #{_editId} modifiée",
                    "Cycle Rules",
                    $"Machine : {_selectedMachine} — Seuil mis à jour");
            }
            _form = null; _editId = null;
            await LoadRules();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task DeleteRule(CycleRuleDto r)
    {
        _error = null;
        try 
