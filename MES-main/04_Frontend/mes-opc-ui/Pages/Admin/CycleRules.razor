            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            _copiedCellId = cellId;
            StateHasChanged();
            await Task.Delay(1500);
            if (_copiedCellId == cellId) { _copiedCellId = null; StateHasChanged(); }
