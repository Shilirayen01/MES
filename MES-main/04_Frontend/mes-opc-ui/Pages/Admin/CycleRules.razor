                                        <circle cx="12" cy="12" r="3"></circle>
                                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                    </svg>
                                </div>
                                @if (ShowViewSettings)
                                {
                                    <div class="vs-popover" @onclick:stopPropagation>
                                        <div class="vs-header">VIEW SETTINGS</div>
                                        <div class="vs-body">
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColId" /> Id</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColScope" /> Scope</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColActive" /> Active</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColStartStrat" /> Start Strategy</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColStartNodeId" /> Start NodeId</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColStartEdge" /> Start Edge</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColStartVal" /> Start Value</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColEndStrat" /> End Strategy</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColEndNodeId" /> End NodeId</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColEndEdge" /> End Edge</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColFallbackStrat" /> Fallback Strat</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColFallbackNode" /> Fallback NodeId</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColAbortNodes" /> Abort NodeIds</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColDebounce" /> Debounce</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColMinCycle" /> Min Cycle</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColTimeout" /> Timeout</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColEpsilon" /> Epsilon</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColTolerance" /> Tolerance</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColSpeedNode" /> Speed NodeId</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColSpeedMin" /> Speed Min</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColStateNode" /> State NodeId</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColStateVal" /> State Value</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColRecovStrat" /> Recovery</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColRecovNode" /> Recov NodeId</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColRecovDelta" /> Delta</label>
                                            <label class="vs-check"><input type="checkbox" @bind="ShowColRecovWin" /> Window (s)</label>
                                        </div>
                                        <div class="vs-footer">
                                            <span class="vs-count">@ActiveColsCount / 26 ACTIVE</span>
                                            <button class="vs-restore" @onclick="RestoreColumns">RESTORE</button>
                                        </div>
                                    </div>
                                }
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _rules)
                        {
                            <tr>
                                @if(ShowColId) { <td><span class="cell-id">@r.Id</span></td> }
                                @if(ShowColScope) { <td><span class="cell-scope">@r.ScopeKey</span></td> }
                                @if(ShowColActive) {
                                    <td>
                                        <label class="toggle-switch @(r.IsActive ? "on" : "")" title="@(r.IsActive ? "Actif" : "Inactif")">
                                            <div class="toggle-track"><div class="toggle-thumb"></div></div>
                                        </label>
                                    </td>
                                }
                                @if(ShowColStartStrat) { <td><span class="cell-strategy">@r.StartStrategy</span></td> }
                                @if(ShowColStartNodeId) {
                                    <td>
                                        <div class="cell-nodeid-container">
                                            <span class="cell-nodeid" title="@r.StartNodeId">@r.StartNodeId</span>
                                            @if (!string.IsNullOrEmpty(r.StartNodeId)) {
                                                <button class="btn-copy-nodeid" @onclick='() => CopyToClipboard(r.StartNodeId, $"{r.Id}-start")'>
                                                    @if (_copiedCellId == $"{r.Id}-start") { <span style="color:var(--green-txt);font-size:10px;font-weight:bold">✓</span> }
                                                    else { <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> }
                                                </button>
                                            }
                                        </div>
                                    </td>
                                }
                                @if(ShowColStartEdge) { <td><span class="cell-edge">@r.StartEdgeType</span></td> }
                                @if(ShowColStartVal) { <td><span class="cell-edge">@r.StartValue</span></td> }
                                @if(ShowColEndStrat) { <td><span class="cell-strategy">@r.EndPrimaryStrategy</span></td> }
                                @if(ShowColEndNodeId) {
                                    <td>
                                        <div class="cell-nodeid-container">
                                            <span class="cell-nodeid" title="@r.EndPrimaryNodeId">@r.EndPrimaryNodeId</span>
                                            @if (!string.IsNullOrEmpty(r.EndPrimaryNodeId)) {
                                                <button class="btn-copy-nodeid" @onclick='() => CopyToClipboard(r.EndPrimaryNodeId, $"{r.Id}-end1")'>
                                                    @if (_copiedCellId == $"{r.Id}-end1") { <span style="color:var(--green-txt);font-size:10px;font-weight:bold">✓</span> }
                                                    else { <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> }
                                                </button>
                                            }
                                        </div>
                                    </td>
                                }
                                @if(ShowColEndEdge) { <td><span class="cell-edge">@r.EndPrimaryEdgeType</span></td> }
                                @if(ShowColFallbackStrat) { <td><span class="cell-strategy">@r.EndFallbackStrategy</span></td> }
                                @if(ShowColFallbackNode) {
                                    <td>
                                        <div class="cell-nodeid-container">
                                            <span class="cell-nodeid" title="@r.EndFallbackNodeId">@r.EndFallbackNodeId</span>
                                            @if (!string.IsNullOrEmpty(r.EndFallbackNodeId)) {
                                                <button class="btn-copy-nodeid" @onclick='() => CopyToClipboard(r.EndFallbackNodeId, $"{r.Id}-endfb")'>
                                                    @if (_copiedCellId == $"{r.Id}-endfb") { <span style="color:var(--green-txt);font-size:10px;font-weight:bold">✓</span> }
                                                    else { <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> }
                                                </button>
                                            }
                                        </div>
                                    </td>
                                }
                                @if(ShowColAbortNodes) {
                                    <td>
                                        <div class="cell-nodeid-container">
                                            <span class="cell-nodeid" title="@r.AbortNodeIds">@r.AbortNodeIds</span>
                                            @if (!string.IsNullOrEmpty(r.AbortNodeIds)) {
                                                <button class="btn-copy-nodeid" @onclick='() => CopyToClipboard(r.AbortNodeIds, $"{r.Id}-abort")'>
                                                    @if (_copiedCellId == $"{r.Id}-abort") { <span style="color:var(--green-txt);font-size:10px;font-weight:bold">✓</span> }
                                                    else { <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> }
                                                </button>
                                            }
                                        </div>
                                    </td>
                                }
                                @if(ShowColDebounce) { <td><span class="cell-num">@r.DebounceMs</span></td> }
                                @if(ShowColMinCycle) { <td><span class="cell-num">@r.MinCycleSeconds</span></td> }
                                @if(ShowColTimeout) { <td><span class="cell-num">@r.TimeoutSeconds</span></td> }
                                @if(ShowColEpsilon) { <td><span class="cell-num">@r.Epsilon</span></td> }
                                @if(ShowColTolerance) { <td><span class="cell-num">@r.TargetTolerance</span></td> }
                                @if(ShowColSpeedNode) { <td><span class="cell-nodeid">@r.ValidationSpeedNodeId</span></td> }
                                @if(ShowColSpeedMin) { <td><span class="cell-num">@r.ValidationSpeedMin</span></td> }
                                @if(ShowColStateNode) { <td><span class="cell-nodeid">@r.ValidationStateNodeId</span></td> }
                                @if(ShowColStateVal) { <td><span class="cell-edge">@r.ValidationStateValue</span></td> }
                                @if(ShowColRecovStrat) { <td><span class="cell-strategy">@r.RecoveryStrategy</span></td> }
                                @if(ShowColRecovNode) { <td><span class="cell-nodeid">@r.RecoveryConfirmNodeId</span></td> }
                                @if(ShowColRecovDelta) { <td><span class="cell-num">@r.RecoveryConfirmDelta</span></td> }
                                @if(ShowColRecovWin) { <td><span class="cell-num">@r.RecoveryConfirmWindowSeconds</span></td> }
                                
                                <td>
                                    <div class="cell-actions">
                                        <button class="icon-btn" title="Edit" @onclick="() => EditRule(r)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        </button>
                                        <button class="icon-btn danger" title="Supprimer" @onclick="() => DeleteRule(r)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (_rules is not null && _rules.Count == 0 && !string.IsNullOrEmpty(_selectedMachine))
    {
        <div class="table-card">
            <div class="empty-state">
                Aucune règle pour <strong style="color:var(--accent)">@_selectedMachine</strong>. Créez-en une ci-dessous.
            </div>
        </div>
    }

    @* ── Edit Form (Drawer) ── *@
    @if (_form is not null && _editId is not null)
    {
        <div class="cr-drawer-overlay" @onclick="Cancel"></div>
        <div class="cr-drawer">
            <div class="cr-drawer-header">
                <div class="cr-drawer-title">Modifier Règle #@_editId</div>
                <button class="icon-btn" style="padding:0;" @onclick="Cancel">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="cr-drawer-body">
                <div class="form-section-label" style="margin-top:0;">Identité</div>
            <div class="form-row">
                <div class="form-group" style="flex:2;">
                    <label>Scope Key</label>
                    <input class="cr-input mono" @bind="_form.ScopeKey" placeholder="default" />
                </div>
                <div class="form-group" style="flex:0;min-width:80px;">
                    <label>&nbsp;</label>
                    <div class="form-check-row">
                        <input type="checkbox" id="chkActive" @bind="_form.IsActive" />
                        <label for="chkActive">Actif</label>
                    </div>
                </div>
            </div>

            <div class="form-section-label">Détection de Début</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Start Strategy</label>
                    <select class="cr-form-select" @bind="_form.StartStrategy">
                        <option>EdgeOnBit</option><option>ValueEquals</option>
                        <option>CounterIncrease</option><option>LastChanged</option>
                    </select>
                </div>
                <div class="form-group" style="flex:3;">
                    <label>Start NodeId</label>
                    <input class="cr-input mono" @bind="_form.StartNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>Edge Type</label>
                    <select class="cr-form-select" @bind="_form.StartEdgeType">
                        <option value="">—</option><option>Rising</option><option>Falling</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Start Value</label>
                    <input class="cr-input" @bind="_form.StartValue" placeholder="optionnel" />
                </div>
            </div>

            <div class="form-section-label">Détection de Fin — Primaire</div>
            <div class="form-row">
                <div class="form-group">
                    <label>End Strategy</label>
                    <select class="cr-form-select" @bind="_form.EndPrimaryStrategy">
                        <option>EdgeOnBit</option><option>LastChanged</option>
                        <option>ValueEquals</option><option>CounterIncrease</option>
                    </select>
                </div>
                <div class="form-group" style="flex:3;">
                    <label>End NodeId</label>
                    <input class="cr-input mono" @bind="_form.EndPrimaryNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>Edge Type</label>
                    <select class="cr-form-select" @bind="_form.EndPrimaryEdgeType">
                        <option value="">—</option><option>Rising</option><option>Falling</option>
                    </select>
                </div>
            </div>

            <div class="form-section-label">Détection de Fin — Fallback</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Fallback Strategy</label>
                    <select class="cr-form-select" @bind="_form.EndFallbackStrategy">
                        <option value="">— Aucun —</option>
                        <option>EdgeOnBit</option><option>LastChanged</option><option>ValueEquals</option>
                    </select>
                </div>
                <div class="form-group" style="flex:3;">
                    <label>Fallback NodeId</label>
                    <input class="cr-input mono" @bind="_form.EndFallbackNodeId" placeholder="ns=2;i=..." />
                </div>
            </div>

            <div class="form-section-label">Annulation (Abort)</div>
            <div class="form-row">
                <div class="form-group" style="flex:4;">
                    <label>Abort NodeIds <span style="color:var(--text-muted);font-size:10px;text-transform:none;">(séparés par ;)</span></label>
                    <input class="cr-input mono" @bind="_form.AbortNodeIds" placeholder="ns=2;i=100;ns=2;i=200" />
                </div>
            </div>

            <div class="form-section-label">Timing</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Debounce (ms)</label>
                    <input class="cr-input" type="number" @bind="_form.DebounceMs" />
                </div>
                <div class="form-group">
                    <label>Cycle Min (s)</label>
                    <input class="cr-input" type="number" @bind="_form.MinCycleSeconds" />
                </div>
                <div class="form-group">
                    <label>Timeout (s)</label>
                    <input class="cr-input" type="number" @bind="_form.TimeoutSeconds" />
                </div>
            </div>

            <div class="form-section-label">Validation</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Epsilon</label>
                    <input class="cr-input" type="number" step="0.001" @bind="_form.Epsilon" />
                </div>
                <div class="form-group">
                    <label>Target Tolerance</label>
                    <input class="cr-input" type="number" step="0.001" @bind="_form.TargetTolerance" />
                </div>
                <div class="form-group" style="flex:2;">
                    <label>Speed NodeId</label>
                    <input class="cr-input mono" @bind="_form.ValidationSpeedNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>Speed Min</label>
                    <input class="cr-input" type="number" step="0.001" @bind="_form.ValidationSpeedMin" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:2;">
                    <label>State NodeId</label>
                    <input class="cr-input mono" @bind="_form.ValidationStateNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>State Value</label>
                    <input class="cr-input" @bind="_form.ValidationStateValue" placeholder="ex: RUNNING" />
                </div>
            </div>

            <div class="form-section-label">Recovery (reprise après redémarrage)</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Recovery Strategy</label>
                    <select class="cr-form-select" @bind="_form.RecoveryStrategy">
                        <option value="">— Aucun —</option>
                        <option>None</option><option>EdgeConfirm</option><option>CounterConfirm</option>
                    </select>
                </div>
                <div class="form-group" style="flex:2;">
                    <label>Confirm NodeId</label>
                    <input class="cr-input mono" @bind="_form.RecoveryConfirmNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>Confirm Delta</label>
                    <input class="cr-input" type="number" step="0.001" @bind="_form.RecoveryConfirmDelta" />
                </div>
                <div class="form-group">
                    <label>Window (s)</label>
                    <input class="cr-input" type="number" @bind="_form.RecoveryConfirmWindowSeconds" />
                </div>
            </div>

            </div>
            <div class="form-actions">
                <button class="cr-btn cr-btn-ghost" @onclick="Cancel">Annuler</button>
                <button class="cr-btn cr-btn-primary" @onclick="Save">Enregistrer</button>
            </div>
        </div>
    }

