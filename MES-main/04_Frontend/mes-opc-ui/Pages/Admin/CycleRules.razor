@page "/admin/cycle-rules"
@using mes_opc_ui.Services.AdminApi
@using mes_opc_ui.Services
@using Microsoft.JSInterop
@inject MachinesApiClient MachinesApi
@inject CycleRulesApiClient CycleRulesApi
@inject ActivityLogService ActivityLog
@inject IJSRuntime JS

<style>
    .cr-page {
        --white:       #ffffff;
        --bg-soft:     #f8fafc;
        --border:      #e8edf5;
        --border-soft: #f1f5f9;
        --accent:      #1e40af;
        --accent-dim:  rgba(30,64,175,0.07);
        --green-bg:    #d1fae5;
        --green-txt:   #065f46;
        --green-bdr:   #a7f3d0;
        --tag-bg:      #dbeafe;
        --tag-txt:     #1e40af;
        --tag-bdr:     #bfdbfe;
        --pink:        #be185d;
        --pink-bg:     #fce7f3;
        --red:         #dc2626;
        --red-bg:      rgba(220,38,38,0.07);
        --red-bdr:     #fecaca;
        --text-900:    #0f172a;
        --text-navy:   #1e4d7b;
        --text-muted:  #64748b;
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text-900);
    }

    /* ── Header ── */
    .cr-page .page-header {
        display: flex; align-items: flex-end; justify-content: space-between;
        margin-bottom: 28px; padding-bottom: 18px; border-bottom: 1px solid var(--border);
    }
    .cr-page .page-header h3 {
        font-size: 24px; font-weight: 800; letter-spacing: -0.5px;
        color: var(--text-900); margin: 0 0 5px 0;
    }
    .cr-page .page-header p { font-size: 13px; color: var(--text-navy); margin: 0; }

    /* ── Toolbar ── */
    .cr-page .toolbar {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 24px; flex-wrap: wrap;
    }
    .cr-page .cr-select {
        background: var(--white); border: 1.5px solid var(--border);
        color: var(--text-900); border-radius: 8px; padding: 8px 12px;
        font-size: 13px; font-family: inherit; min-width: 220px;
        transition: border-color 0.15s; cursor: pointer;
    }
    .cr-page .cr-select:focus {
        outline: none; border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-dim);
    }

    /* ── Buttons ── */
    .cr-page .cr-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; border: 1px solid transparent;
        line-height: 1.4; font-family: inherit;
    }
    .cr-page .cr-btn-primary {
        background: var(--accent); color: #fff; border-color: var(--accent);
    }
    .cr-page .cr-btn-primary:hover {
        background: #1e3a8a; box-shadow: 0 4px 14px rgba(30,64,175,0.25); transform: translateY(-1px);
    }
    .cr-page .cr-btn-ghost {
        background: var(--white); color: var(--text-muted); border-color: var(--border);
    }
    .cr-page .cr-btn-ghost:hover {
        color: var(--text-900); border-color: #c8d2e0; background: var(--bg-soft);
    }
    .cr-page .cr-btn-outline {
        background: var(--accent-dim); color: var(--accent);
        border-color: var(--tag-bdr); padding: 4px 12px; font-size: 12px; border-radius: 6px;
    }
    .cr-page .cr-btn-outline:hover { background: var(--tag-bg); }
    .cr-page .cr-btn-danger {
        background: var(--red-bg); color: var(--red);
        border-color: var(--red-bdr); padding: 4px 12px; font-size: 12px; border-radius: 6px;
    }
    .cr-page .cr-btn-danger:hover { background: #fee2e2; }

    /* ── Alerts ── */
    .cr-page .cr-alert-danger {
        background: var(--red-bg); border: 1px solid var(--red-bdr);
        color: var(--red); border-radius: 10px; padding: 12px 16px;
        font-size: 13px; margin-bottom: 16px;
    }
    .cr-page .cr-alert-info {
        background: var(--accent-dim); border: 1px solid var(--tag-bdr);
        color: var(--accent); border-radius: 10px; padding: 12px 16px;
        font-size: 13px; margin-bottom: 16px;
    }

    /* ── Table Card ── */
    .cr-page .table-card {
        background: var(--white); border: 1px solid var(--border);
        border-radius: 14px; overflow: hidden; margin-bottom: 28px;
        box-shadow: 0 1px 4px rgba(15,23,42,0.05);
        animation: crFadeUp 0.35s ease both;
    }
    .cr-page .table-card-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 18px; border-bottom: 1px solid var(--border);
        background: var(--bg-soft);
    }
    .cr-page .table-card-title {
        font-size: 13px; font-weight: 700; color: var(--text-900);
        display: flex; align-items: center; gap: 8px;
    }
    .cr-page .rules-count {
        display: inline-flex; align-items: center; padding: 2px 9px;
        border-radius: 10px; background: var(--accent-dim);
        border: 1px solid var(--tag-bdr); color: var(--accent);
        font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700;
    }
    @@keyframes crFadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Table ── */
    .cr-page .table-scroll { overflow-x: auto; min-height: 350px; }
    .cr-page .table-scroll::-webkit-scrollbar { height: 8px; }
    .cr-page .table-scroll::-webkit-scrollbar-track { background: var(--bg-soft); border-radius: 4px; margin: 0 4px; }
    .cr-page .table-scroll::-webkit-scrollbar-thumb { background: #64748b; border-radius: 4px; }
    .cr-page .table-scroll::-webkit-scrollbar-thumb:hover { background: #475569; }

    .cr-page .cr-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    
    /* ── EWM-style HEADER ── */
    .cr-page .cr-table thead > tr > th {
        background-color: #020495; color: #ffffff;
        font-size: 11px; font-weight: 800; text-transform: uppercase;
        letter-spacing: 0.5px; padding: 10px 14px;
        border: 1px solid rgba(255,255,255,0.2); white-space: nowrap; vertical-align: middle;
    }
    
    .cr-page .th-inner { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
    .cr-page .th-label { flex: 1; }

    /* ── View Settings Popover ── */
    .cr-page .vs-popover {
        position: absolute; top: calc(100% + 5px); right: 0;
        background: #fff; border: 1px solid #e2e8f0; border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15); width: 220px;
        max-height: 400px; overflow-y: auto; overflow-x: hidden;
        z-index: 100; color: #0f172a; text-align: left;
        display: flex; flex-direction: column;
        animation: vsFade 0.15s ease-out; font-family: 'DM Sans', sans-serif;
    }
    @@keyframes vsFade { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
    .cr-page .vs-header {
        font-size: 10px; font-weight: 800; color: #94a3b8;
        padding: 12px 14px 8px; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .cr-page .vs-body { padding: 4px 14px 12px; display: flex; flex-direction: column; gap: 8px; }
    .cr-page .vs-check { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px; font-weight: 500; font-family: inherit; }
    .cr-page .vs-check input[type="checkbox"] { accent-color: #020495; width: 14px; height: 14px; cursor: pointer; }
    .cr-page .vs-footer {
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 14px; background: #f8fafc; border-top: 1px solid #e2e8f0; position: sticky; bottom: 0;
    }
    .cr-page .vs-count { font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; }
    .cr-page .vs-restore { font-size: 10px; font-weight: 800; color: #020495; cursor: pointer; background: none; border: none; text-transform: uppercase; transition: color 0.15s; font-family: inherit; padding: 0; }
    .cr-page .vs-restore:hover { color: #010370; text-decoration: underline; }
    .cr-page .cr-table td {
        padding: 10px 14px; color: var(--text-900);
        border: 1px solid #1e3a5f; vertical-align: middle;
        white-space: nowrap;
    }
    .cr-page .cr-table tbody tr:hover td { background: #eff6ff; }

    /* ── Cell types ── */
    .cr-page .cell-id {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        color: var(--text-muted); font-weight: 600;
    }
    .cr-page .cell-scope {
        font-family: 'JetBrains Mono', monospace; font-size: 12px;
        font-weight: 700; color: var(--pink);
    }
    /* ── NodeId Cell with copy ── */
    .cr-page .cell-nodeid-container {
        display: flex; align-items: center; gap: 4px; max-width: 180px;
    }
    .cr-page .cell-nodeid {
        font-family: 'Consolas', 'Roboto Mono', 'JetBrains Mono', monospace; font-size: 12px;
        color: var(--text-navy); overflow: hidden; text-overflow: ellipsis;
        white-space: nowrap; display: block; flex: 1;
    }
    .cr-page .btn-copy-nodeid {
        background: transparent; border: none; padding: 3px;
        border-radius: 4px; color: var(--text-muted); cursor: pointer;
        opacity: 0; transition: opacity 0.2s, background 0.2s;
        display: flex; align-items: center; flex-shrink: 0;
    }
    .cr-page .cell-nodeid-container:hover .btn-copy-nodeid { opacity: 1; }
    .cr-page .btn-copy-nodeid:hover { background: var(--bg-soft); color: var(--accent); }
    .cr-page .cell-strategy { font-size: 11px; color: var(--accent); font-weight: 600; }
    .cr-page .cell-edge    { font-size: 11px; color: var(--text-muted); }
    .cr-page .cell-num {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        color: var(--text-navy); text-align: right;
    }
    .cr-page .cell-actions { display: flex; align-items: center; justify-content: center; gap: 6px; white-space: nowrap; }

    /* ── Actions ── */
    .cr-page .icon-btn {
        background: none; border: none; cursor: pointer; padding: 4px 6px;
        color: #475569; display: flex; flex-direction: row;
        align-items: center; gap: 5px; transition: color 0.15s;
        font-size: 11px; font-weight: 600; font-family: inherit;
        border-radius: 6px;
    }
    .cr-page .icon-btn:hover { color: #020495; background: #f1f5f9; }
    .cr-page .icon-btn.danger:hover { color: #dc2626; background: #fef2f2; }

    /* ── Toggle Switch ── */
    .cr-page .toggle-switch {
        display: inline-flex; align-items: center; cursor: pointer;
        gap: 6px;
    }
    .cr-page .toggle-switch input { position: absolute; opacity: 0; width: 0; height: 0; }
    .cr-page .toggle-track {
        width: 36px; height: 20px; border-radius: 10px; position: relative;
        transition: background 0.2s;
        background: #cbd5e1;
    }
    .cr-page .toggle-switch.on .toggle-track { background: var(--green-txt); }
    .cr-page .toggle-thumb {
        position: absolute; top: 2px; left: 2px;
        width: 16px; height: 16px; border-radius: 50%;
        background: white; box-shadow: 0 1px 4px rgba(0,0,0,0.2);
        transition: left 0.2s;
    }
    .cr-page .toggle-switch.on .toggle-thumb { left: 18px; }
    @@keyframes crPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* ── Empty state ── */
    .cr-page .empty-state {
        padding: 48px 24px; text-align: center;
        color: var(--text-muted); font-size: 13px;
    }

    /* ── Drawer ── */
    .cr-drawer-overlay {
        position: fixed; inset: 0; background: rgba(15, 23, 42, 0.4);
        z-index: 1000; backdrop-filter: blur(2px);
        animation: crFadeIn 0.2s ease-out forwards;
    }
    .cr-drawer {
        position: fixed; top: 0; right: 0; bottom: 0; width: 550px; max-width: 100vw;
        background: var(--white); z-index: 1001;
        box-shadow: -4px 0 24px rgba(0,0,0,0.1);
        display: flex; flex-direction: column;
        transform: translateX(100%);
        animation: crSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @@keyframes crFadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes crSlideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }

    .cr-drawer-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 24px; border-bottom: 1px solid var(--border); background: var(--bg-soft);
    }
    .cr-drawer-title { font-size: 16px; font-weight: 800; color: var(--text-900); display: flex; align-items: center; gap: 8px; }
    .cr-drawer-body {
        flex: 1; overflow-y: auto; padding: 24px;
        display: flex; flex-direction: column; gap: 10px;
    }
    .cr-page .form-section-label {
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.6px; color: var(--accent);
        margin: 20px 0 10px 0; display: flex; align-items: center; gap: 8px;
    }
    .cr-page .form-section-label::after {
        content: ''; flex: 1; height: 1px; background: var(--border);
    }
    .cr-page .form-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 10px; }
    .cr-page .form-group {
        display: flex; flex-direction: column; gap: 5px; flex: 1; min-width: 130px;
    }
    .cr-page .form-group label {
        font-size: 11px; color: var(--text-navy); font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.5px;
    }
    .cr-page .cr-input, .cr-page .cr-form-select {
        background: var(--bg-soft); border: 1.5px solid var(--border);
        color: var(--text-900); border-radius: 8px; padding: 8px 10px;
        font-size: 13px; font-family: inherit; transition: border-color 0.15s; width: 100%;
    }
    .cr-page .cr-input:focus, .cr-page .cr-form-select:focus {
        outline: none; border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-dim);
    }
    .cr-page .cr-input.mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; }
    .cr-page .form-check-row { display: flex; align-items: center; gap: 8px; padding-top: 22px; }
    .cr-page .form-check-row input[type="checkbox"] {
        width: 15px; height: 15px; accent-color: var(--accent); cursor: pointer;
    }
    .cr-page .form-check-row label { font-size: 13px; color: var(--text-900); cursor: pointer; }
    .cr-page .form-actions {
        display: flex; gap: 10px; justify-content: flex-end;
        padding: 16px 24px; border-top: 1px solid var(--border); background: var(--bg-soft);
    }
</style>

<div class="cr-page">

    @* ── Page Header ── *@
    <div class="page-header">
        <div>
            <h3>@Loc.T("page.rules.title")</h3>
            <p>@Loc.T("page.rules.subtitle")</p>
        </div>
    </div>

    @* ── Toolbar ── *@
    <div class="toolbar" style="justify-content: space-between;">
        <select class="cr-select" @bind="_selectedMachine" @bind:after="LoadRules" style="min-width:200px;">
            <option value="">@Loc.T("common.select_machine")</option>
            @foreach (var m in _machines)
            {
                <option value="@m.MachineCode">@m.MachineCode — @m.Name</option>
            }
        </select>
        <div style="display: flex; gap: 10px; align-items: center;">
            <button class="cr-btn cr-btn-ghost" @onclick="LoadRules">@Loc.T("common.refresh")</button>
            @if (!string.IsNullOrEmpty(_selectedMachine))
            {
                <button class="cr-btn cr-btn-primary" @onclick="NewRule">@Loc.T("common.new")</button>
            }
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="cr-alert-danger">@(_error.Contains("Failed to fetch") ? Loc.T("common.error_fetch") : _error)</div>
    }

    @* ── Create Form (Drawer) ── *@
    @if (_form is not null && _editId is null)
    {
        <div class="cr-drawer-overlay" @onclick="Cancel"></div>
        <div class="cr-drawer">
            <div class="cr-drawer-header">
                <div class="cr-drawer-title">Créer une Règle</div>
                <button class="icon-btn" style="padding:0;" @onclick="Cancel">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="cr-drawer-body">
                <div class="form-section-label" style="margin-top:0;">Identité</div>
            <div class="form-row">
                <div class="form-group" style="flex:2;">
                    <label>Scope Key</label>
                    <input class="cr-input mono" @bind="_form.ScopeKey" placeholder="default" />
                </div>
                <div class="form-group" style="flex:0;min-width:80px;">
                    <label>&nbsp;</label>
                    <div class="form-check-row">
                        <input type="checkbox" id="chkActiveTop" @bind="_form.IsActive" />
                        <label for="chkActiveTop">Actif</label>
                    </div>
                </div>
            </div>

            <div class="form-section-label">Détection de Début</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Start Strategy</label>
                    <select class="cr-form-select" @bind="_form.StartStrategy">
                        <option>EdgeOnBit</option><option>ValueEquals</option>
                        <option>CounterIncrease</option><option>LastChanged</option>
                    </select>
                </div>
                <div class="form-group" style="flex:3;">
                    <label>Start NodeId</label>
                    <input class="cr-input mono" @bind="_form.StartNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>Edge Type</label>
                    <select class="cr-form-select" @bind="_form.StartEdgeType">
                        <option value="">—</option><option>Rising</option><option>Falling</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Start Value</label>
                    <input class="cr-input" @bind="_form.StartValue" placeholder="optionnel" />
                </div>
            </div>

            <div class="form-section-label">Détection de Fin — Primaire</div>
            <div class="form-row">
                <div class="form-group">
                    <label>End Strategy</label>
                    <select class="cr-form-select" @bind="_form.EndPrimaryStrategy">
                        <option>EdgeOnBit</option><option>LastChanged</option>
                        <option>ValueEquals</option><option>CounterIncrease</option>
                    </select>
                </div>
                <div class="form-group" style="flex:3;">
                    <label>End NodeId</label>
                    <input class="cr-input mono" @bind="_form.EndPrimaryNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>Edge Type</label>
                    <select class="cr-form-select" @bind="_form.EndPrimaryEdgeType">
                        <option value="">—</option><option>Rising</option><option>Falling</option>
                    </select>
                </div>
            </div>

            <div class="form-section-label">Détection de Fin — Fallback (optionnel)</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Fallback Strategy</label>
                    <select class="cr-form-select" @bind="_form.EndFallbackStrategy">
                        <option value="">— Aucun —</option>
                        <option>EdgeOnBit</option><option>LastChanged</option>
                        <option>ValueEquals</option><option>CounterIncrease</option>
                    </select>
                </div>
                <div class="form-group" style="flex:3;">
                    <label>Fallback NodeId</label>
                    <input class="cr-input mono" @bind="_form.EndFallbackNodeId" placeholder="ns=2;i=..." />
                </div>
            </div>

            <div class="form-section-label">Sécurité / Echec (Abort)</div>
            <div class="form-row">
                <div class="form-group full-width">
                    <label>Abort NodeIds (séparés par point-virgule)</label>
                    <input class="cr-input mono" @bind="_form.AbortNodeIds" placeholder="ns=2;i=Tag1;ns=2;i=Tag2" />
                </div>
            </div>

            <div class="form-section-label">Timing & Tolérances</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Debounce (ms)</label>
                    <input class="cr-input" type="number" @bind="_form.DebounceMs" />
                </div>
                <div class="form-group">
                    <label>Min Cycle (s)</label>
                    <input class="cr-input" type="number" @bind="_form.MinCycleSeconds" />
                </div>
                <div class="form-group">
                    <label>Timeout (s)</label>
                    <input class="cr-input" type="number" @bind="_form.TimeoutSeconds" />
                </div>
                <div class="form-group">
                    <label>Epsilon</label>
                    <input class="cr-input" type="number" step="0.001" @bind="_form.Epsilon" />
                </div>
                <div class="form-group">
                    <label>Target Tolerance</label>
                    <input class="cr-input" type="number" step="0.001" @bind="_form.TargetTolerance" />
                </div>
                <div class="form-group" style="flex:2;">
                    <label>Speed NodeId</label>
                    <input class="cr-input mono" @bind="_form.ValidationSpeedNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>Speed Min</label>
                    <input class="cr-input" type="number" step="0.001" @bind="_form.ValidationSpeedMin" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:2;">
                    <label>State NodeId</label>
                    <input class="cr-input mono" @bind="_form.ValidationStateNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>State Value</label>
                    <input class="cr-input" @bind="_form.ValidationStateValue" placeholder="ex: RUNNING" />
                </div>
            </div>

            <div class="form-section-label">Recovery (reprise après redémarrage)</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Recovery Strategy</label>
                    <select class="cr-form-select" @bind="_form.RecoveryStrategy">
                        <option value="">— Aucun —</option>
                        <option>None</option><option>EdgeConfirm</option><option>CounterConfirm</option>
                    </select>
                </div>
                <div class="form-group" style="flex:2;">
                    <label>Confirm NodeId</label>
                    <input class="cr-input mono" @bind="_form.RecoveryConfirmNodeId" placeholder="ns=2;i=..." />
                </div>
                <div class="form-group">
                    <label>Confirm Delta</label>
                    <input class="cr-input" type="number" step="0.001" @bind="_form.RecoveryConfirmDelta" />
                </div>
                <div class="form-group">
                    <label>Window (s)</label>
                    <input class="cr-input" type="number" @bind="_form.RecoveryConfirmWindowSeconds" />
                </div>
            </div>
            </div>
            <div class="form-actions">
                <button type="button" class="cr-btn cr-btn-ghost" @onclick="Cancel">Annuler</button>
                <button type="button" class="cr-btn cr-btn-primary" @onclick="Save">Enregistrer</button>
            </div>
        </div>
