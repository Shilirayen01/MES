                            @if(ShowColStartStrat) { <th><div class="th-inner"><span class="th-label">@Loc.T("page.rules.start") Strategy</span></div></th> }
                            @if(ShowColStartNodeId) { <th><div class="th-inner"><span class="th-label">@Loc.T("page.rules.start") NodeId</span></div></th> }
