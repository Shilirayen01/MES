                            @if(ShowColEndStrat) { <th><div class="th-inner"><span class="th-label">End Strategy</span></div></th> }
                            @if(ShowColEndNodeId) { <th><div class="th-inner"><span class="th-label">End NodeId</span></div></th> }
                            @if(ShowColEndEdge) { <th><div class="th-inner"><span class="th-label">End Edge</span></div></th> }
                            @if(ShowColFallbackStrat) { <th><div class="th-inner"><span class="th-label">Fallback Strat</span></div></th> }
                            @if(ShowColFallbackNode) { <th><div class="th-inner"><span class="th-label">Fallback NodeId</span></div></th> }
                            @if(ShowColAbortNodes) { <th><div class="th-inner"><span class="th-label">Abort NodeIds</span></div></th> }
                            @if(ShowColDebounce) { <th><div class="th-inner"><span class="th-label">Debounce (ms)</span></div></th> }
                            @if(ShowColMinCycle) { <th><div class="th-inner"><span class="th-label">Min Cycle (s)</span></div></th> }
                            @if(ShowColTimeout) { <th><div class="th-inner"><span class="th-label">Timeout (s)</span></div></th> }
                            @if(ShowColEpsilon) { <th><div class="th-inner"><span class="th-label">Epsilon</span></div></th> }
                            @if(ShowColTolerance) { <th><div class="th-inner"><span class="th-label">Tolerance</span></div></th> }
                            @if(ShowColSpeedNode) { <th><div class="th-inner"><span class="th-label">Speed NodeId</span></div></th> }
                            @if(ShowColSpeedMin) { <th><div class="th-inner"><span class="th-label">Speed Min</span></div></th> }
                            @if(ShowColStateNode) { <th><div class="th-inner"><span class="th-label">State NodeId</span></div></th> }
                            @if(ShowColStateVal) { <th><div class="th-inner"><span class="th-label">State Value</span></div></th> }
                            @if(ShowColRecovStrat) { <th><div class="th-inner"><span class="th-label">Recovery</span></div></th> }
                            @if(ShowColRecovNode) { <th><div class="th-inner"><span class="th-label">Recov NodeId</span></div></th> }
                            @if(ShowColRecovDelta) { <th><div class="th-inner"><span class="th-label">Delta</span></div></th> }
                            @if(ShowColRecovWin) { <th><div class="th-inner"><span class="th-label">Window (s)</span></div></th> }

                            <th style="position: relative;">
                                <div class="th-inner" style="justify-content: space-between;">
                                    <span class="th-label">@Loc.T("common.actions")</span>
