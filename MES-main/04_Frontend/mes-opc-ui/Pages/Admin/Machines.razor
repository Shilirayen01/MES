@page "/admin/machines"
@using mes_opc_ui.Services.AdminApi
@using Microsoft.AspNetCore.Components.Forms
@inject MachinesApiClient MachinesApi
@inject OpcEndpointsApiClient EndpointsApi
@inject NavigationManager Nav

<h3>Machines</h3>

<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
    <button class="btn btn-sm btn-primary" @onclick="New">+ Nouvelle Machine</button>
    <label class="form-check form-check-inline mb-0">
        <input class="form-check-input" type="checkbox" @bind="ShowOnlyActive" />
        <span class="form-check-label">Afficher seulement actifs</span>
    </label>
    <button class="btn btn-sm btn-outline-light" @onclick="Load">Rafraîchir</button>
</div>

@if (Error is not null)
{
    <div style="color:red">@Error</div>
}

@if (Items is null || Endpoints is null)
{
    <p>Chargement...</p>
}
else
{
    <div class="table-responsive">
    <table class="table table-dark table-striped table-hover align-middle">
        <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Line</th>
            <th>EndpointId</th>
            <th>Active</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var m in Items)
        {
            <tr>
                <td>@m.MachineCode</td>
                <td>@m.Name</td>
                <td>@m.LineCode</td>
                <td>@m.OpcEndpointId</td>
                <td>@(m.IsActive ? "Yes" : "No")</td>
                <td>
                    <button class="btn btn-sm btn-outline-info" @onclick="() => Edit(m)">Edit</button>
                    <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="() => GoMappings(m)">TagMappings</button>
                    <button class="btn btn-sm btn-outline-warning ms-2" @onclick="() => Deactivate(m)">Désactiver</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
}

@if (FormCreate is not null)
{
    <hr />
    <h4>Créer Machine</h4>
    <EditForm Model="FormCreate" OnValidSubmit="SaveCreate">
        <div>
            <label>MachineCode</label><br />
            <InputText class="form-control" @bind-Value="FormCreate.MachineCode" />
        </div>

        <div style="margin-top:8px;">
            <label>Name</label><br />
            <InputText class="form-control" @bind-Value="FormCreate.Name" />
        </div>

        <div style="margin-top:8px;">
            <label>LineCode</label><br />
            <InputText class="form-control" @bind-Value="FormCreate.LineCode" />
        </div>

        <div style="margin-top:8px;">
            <label>OpcEndpoint</label><br />
            <select class="form-select" @bind="FormCreate.OpcEndpointId">
                @foreach (var e in Endpoints)
                {
                    <option value="@e.Id">@e.Id - @e.Name</option>
                }
            </select>
        </div>

        <div style="margin-top:8px;">
            <label>Active</label>
            <InputCheckbox class="form-check-input" @bind-Value="FormCreate.IsActive" />
        </div>



        <div style="margin-top:12px;">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <button type="button" class="btn btn-outline-light ms-2" @onclick="Cancel">Annuler</button>
        </div>
    </EditForm>
}

@if (FormUpdate is not null)
{
    <hr />
    <h4>Modifier Machine (@EditCode)</h4>
    <EditForm Model="FormUpdate" OnValidSubmit="SaveUpdate">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div>
            <label>Name</label><br />
            <InputText class="form-control" @bind-Value="FormUpdate.Name" />
        </div>

        <div style="margin-top:8px;">
            <label>LineCode</label><br />
            <InputText class="form-control" @bind-Value="FormUpdate.LineCode" />
        </div>

        <div style="margin-top:8px;">
            <label>OpcEndpoint</label><br />
            <select class="form-select" @bind="FormUpdate.OpcEndpointId">
                @foreach (var e in Endpoints)
                {
                    <option value="@e.Id">@e.Id - @e.Name</option>
                }
            </select>
        </div>

        <div style="margin-top:8px;">
            <label>Active</label>
            <InputCheckbox class="form-check-input" @bind-Value="FormUpdate.IsActive" />
        </div>


        <div style="margin-top:12px;">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <button type="button" class="btn btn-outline-light ms-2" @onclick="Cancel">Annuler</button>
        </div>
    </EditForm>
}

@code {
    private List<MachineDto>? Items;
    private List<OpcEndpointDto>? Endpoints;
    private string? Error;
    private bool ShowOnlyActive = true;

    private MachineCreateDto? FormCreate;
    private MachineUpdateDto? FormUpdate;
    private string EditCode = "";

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        Error = null;
        Items = null;
        Endpoints = null;
        StateHasChanged();

        try
        {
            Endpoints = await EndpointsApi.GetAllAsync(true) ?? [];
            Items = await MachinesApi.GetAllAsync(ShowOnlyActive ? true : null) ?? [];
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            Endpoints ??= [];
            Items ??= [];
        }
    }

    private void New()
    {
        FormUpdate = null;
        EditCode = "";
        FormCreate = new MachineCreateDto
        {
            IsActive = true,
            OpcEndpointId = Endpoints?.FirstOrDefault()?.Id ?? 1
        };
    }

    private void Edit(MachineDto m)
    {
        FormCreate = null;
        EditCode = m.MachineCode;

        FormUpdate = new MachineUpdateDto
        {
            Name = m.Name,
            LineCode = m.LineCode,
            OpcEndpointId = m.OpcEndpointId,
            IsActive = m.IsActive
        };
    }

    private async Task SaveCreate()
    {
        if (FormCreate is null) return;
        try
        {
            await MachinesApi.CreateAsync(FormCreate);
            FormCreate = null;
            await Load();
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task SaveUpdate()
    {
        if (FormUpdate is null) return;
        try
        {
            await MachinesApi.UpdateAsync(EditCode, FormUpdate);
            FormUpdate = null;
            EditCode = "";
            await Load();
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private async Task Deactivate(MachineDto m)
    {
        try
        {
            await MachinesApi.DeleteAsync(m.MachineCode);
            await Load();
        }
        catch (Exception ex) { Error = ex.Message; }
    }

    private void GoMappings(MachineDto m)
        => Nav.NavigateTo($"/admin/machines/{Uri.EscapeDataString(m.MachineCode)}/tag-mappings");

    private void Cancel()
    {
        FormCreate = null;
        FormUpdate = null;
        EditCode = "";
    }
}
