@page "/"
@page "/dashboard/{DashboardId:guid}"
@implements IDisposable
@using Mes.Opc.Contracts.Dtos
@inject mes_opc_ui.Services.UiConfigurationService Ui
@inject mes_opc_ui.Services.RealtimeHubService Hub
@inject mes_opc_ui.Services.WidgetValueStore Store
@inject HttpClient Http
@inject mes_opc_ui.Services.ClientEndpoints Endpoints
@inject NavigationManager NavigationManager

<style>
    .db-page {
        --white:      #ffffff;
        --bg-soft:    #f8fafc;
        --border:     #e8edf5;
        --border-soft:#f1f5f9;
        --accent:     #1e40af;
        --accent-dim: rgba(30,64,175,0.07);
        --green:      #059669;
        --green-bg:   #d1fae5;
        --green-bdr:  #a7f3d0;
        --red:        #dc2626;
        --red-bg:     rgba(220,38,38,0.07);
        --red-bdr:    #fecaca;
        --orange-bg:  #fffbeb;
        --orange-bdr: #fde68a;
        --orange-txt: #92400e;
        --text-900:   #0f172a;
        --text-navy:  #1e4d7b;
        --text-muted: #64748b;
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text-900);
    }

    /* ── Header ── */
    .db-page .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
        padding-bottom: 18px;
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
        gap: 12px;
    }
    .db-page .page-header h2 {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.6px;
        color: var(--text-900);
        margin: 0;
    }

    /* ── Status Bar ── */
    .db-page .status-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }
    .db-page .status-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.1px;
        border: 1px solid transparent;
    }
    .db-page .status-chip .dot {
        width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
    }
    .db-page .status-connected {
        background: var(--green-bg);
        border-color: var(--green-bdr);
        color: var(--green);
    }
    .db-page .status-connected .dot {
        background: var(--green);
        animation: dbPulse 2s ease infinite;
    }
    .db-page .status-disconnected {
        background: var(--bg-soft);
        border-color: var(--border);
        color: var(--text-muted);
    }
    .db-page .status-disconnected .dot { background: #cbd5e1; }
    .db-page .status-error {
        background: var(--red-bg);
        border-color: var(--red-bdr);
        color: var(--red);
    }
    .db-page .status-error .dot { background: var(--red); animation: dbPulse 1s ease infinite; }

    @@keyframes dbPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

    .db-page .db-btn-reconnect {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 14px; border-radius: 8px; font-size: 12px; font-weight: 600;
        cursor: pointer; transition: all 0.15s; font-family: inherit;
        background: var(--white); color: var(--accent);
        border: 1px solid #bfdbfe;
    }
    .db-page .db-btn-reconnect:hover {
        background: var(--accent-dim); border-color: var(--accent);
    }

    /* ── Alerts ── */
    .db-page .db-alert {
        border-radius: 12px; padding: 16px 20px; font-size: 13px; margin-bottom: 24px;
    }
    .db-page .db-alert-info {
        background: var(--accent-dim); border: 1px solid #bfdbfe; color: var(--accent);
    }
    .db-page .db-alert-warning {
        background: var(--orange-bg); border: 1px solid var(--orange-bdr); color: var(--orange-txt);
    }
    .db-page .db-alert code {
        font-family: 'JetBrains Mono', monospace; font-size: 11px;
        background: rgba(30,64,175,0.08); padding: 2px 7px;
        border-radius: 5px; color: var(--accent);
    }
    .db-page .db-alert-title {
        font-weight: 700; font-size: 14px; margin-bottom: 6px;
        display: flex; align-items: center; gap: 8px;
    }
    .db-page .db-alert-sub { font-size: 12px; margin-top: 6px; color: var(--orange-txt); opacity: 0.85; }

    /* ── Zone Tabs ── */
    .db-page .db-tabs {
        display: flex; gap: 8px; margin-bottom: 24px;
        overflow-x: auto; padding-bottom: 4px;
    }
    .db-page .db-tab {
        padding: 8px 18px; border: 1px solid var(--border);
        background: var(--white); border-radius: 20px;
        font-size: 13px; font-weight: 600; color: var(--text-navy);
        cursor: pointer; transition: all 0.2s; white-space: nowrap;
        box-shadow: 0 1px 2px rgba(15,23,42,0.03);
    }
    .db-page .db-tab:hover {
        border-color: var(--accent-dim); background: var(--bg-soft);
    }
    .db-page .db-tab.active {
        background: var(--accent); color: var(--white);
        border-color: var(--accent); box-shadow: 0 4px 10px rgba(30,64,175,0.2);
    }

    /* ── Zone Card ── */
    .db-page .zone-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 20px;
        animation: dbFadeUp 0.35s ease both;
        box-shadow: 0 1px 4px rgba(15,23,42,0.05);
    }
    .db-page .zone-card:hover {
        box-shadow: 0 4px 16px rgba(15,23,42,0.08);
    }
    @@keyframes dbFadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .db-page .zone-card:nth-child(1) { animation-delay: 0.05s; }
    .db-page .zone-card:nth-child(2) { animation-delay: 0.10s; }
    .db-page .zone-card:nth-child(3) { animation-delay: 0.15s; }
    .db-page .zone-card:nth-child(4) { animation-delay: 0.20s; }

    /* ── Zone Header ── */
    .db-page .zone-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 13px 20px;
        border-bottom: 1px solid var(--border-soft);
        background: var(--bg-soft);
        border-radius: 14px 14px 14px 14px;
    }
    .db-page .zone-header-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
    }
    .db-page .zone-title {
        font-size: 13px; font-weight: 700;
        color: var(--text-900); letter-spacing: 0.1px;
    }

    /* ── Zone Body ── */
    .db-page .zone-body {
        padding: 18px 20px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 14px;
        transition: all 0.3s;
    }
</style>

<div class="db-page">

    @* ── Page Header ── *@
    <div class="page-header">
        <h2><a style="color: var(--text-900); text-decoration: none;" href="/admin/ui-dashboards">Dashboard</a></h2>

        <div class="status-bar">
            @if (Hub.IsConnected)
            {
                <span class="status-chip status-connected">
                    <span class="dot"></span> Realtime connecté
                </span>
            }
            else
            {
                <span class="status-chip status-disconnected">
                    <span class="dot"></span> Realtime déconnecté
                </span>
            }

            @if (!string.IsNullOrWhiteSpace(_rtError) || !string.IsNullOrWhiteSpace(Hub.LastError))
            {
                <span class="status-chip status-error">
                    <span class="dot"></span> @(_rtError ?? Hub.LastError)
                </span>
                <button class="db-btn-reconnect" @onclick="Reconnect">↻ Reconnect</button>
            }
        </div>
    </div>

    @* ── Tabs ── *@
    @if (_loading)
    {
        <div class="db-alert db-alert-info">
            <div class="db-alert-title">⏳ Chargement…</div>
            Récupération de la configuration du dashboard en cours.
        </div>
    }
    else if (_dashboard is null)
    {
        <div class="db-alert db-alert-warning">
            <div class="db-alert-title">⚠ Aucun dashboard trouvé</div>
            <div class="db-alert-sub">
                Exécutez le script SQL pour créer un dashboard par défaut :<br />
                <code>05_Tools/Mes.Opc.Admin.Seed/sql/ui_schema_and_seed.sql</code>
            </div>
        </div>
    }
    else
    {
        @if (_dashboard.Zones.Count > 0)
        {
            <div class="db-tabs">
                @foreach (var zone in _dashboard.Zones)
                {
                    <button class="db-tab @(zone.Id == _activeZoneId ? "active" : "")" @onclick="() => _activeZoneId = zone.Id">
                        @zone.Title
                    </button>
                }
            </div>

            var activeZone = _dashboard.Zones.FirstOrDefault(z => z.Id == _activeZoneId);
            if (activeZone is not null)
            {
                <section class="zone-card">
                    <div class="zone-body" @onmouseenter="() => _isHoveringWidgets = true" @onmouseleave="() => _isHoveringWidgets = false">
                        @foreach (var widget in activeZone.Widgets.OrderByDescending(w => _widgetUpdateTimes.GetValueOrDefault(w.Id, DateTime.MinValue)))
                        {
                            <WidgetRenderer Widget="widget" />
                        }
                    </div>
                </section>
            }
        }
    }

</div>

@code {
    [Parameter]
    public Guid DashboardId { get; set; }

    private bool _loading = true;
    private DashboardDto? _dashboard;
    private Guid _activeZoneId = Guid.Empty;
    private Dictionary<Guid, DateTime> _widgetUpdateTimes = new();
    private bool _isHoveringWidgets = false;
    private DateTime _lastUiSortTime = DateTime.MinValue;
    private bool _hubStarted;
    private string? _rtError;

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnStoreChanged;
        Hub.StateChanged += OnHubStateChanged;
        Hub.WidgetUpdated += OnWidgetUpdated;
        Hub.WidgetUpdated += Store.OnWidgetUpdate;
        await LoadDashboardAsync();
    }

    private void OnWidgetUpdated(WidgetUpdateDto update)
    {
        _widgetUpdateTimes[update.WidgetId] = DateTime.Now;

        if (_isHoveringWidgets) return;
        
        // Throttle UI re-sort to every 3 seconds
        if ((DateTime.Now - _lastUiSortTime).TotalSeconds > 3)
        {
            _lastUiSortTime = DateTime.Now;
            InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // If the route changes while on the component, reload the dashboard
        if (!_loading)
        {
            await LoadDashboardAsync();
            // Assuming realtime reconnect might be needed if dashboard changes
            _hubStarted = false; 
            StateHasChanged();
        }
    }

    private async Task LoadDashboardAsync()
    {
        _loading = true;
        _dashboard = null;
        StateHasChanged();
        
        try
        {
            _dashboard = await Ui.GetDashboardAsync(DashboardId);
            
            if (_dashboard is not null)
            {
                Store.Configure(_dashboard);
                _activeZoneId = _dashboard.Zones.FirstOrDefault()?.Id ?? Guid.Empty;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_hubStarted || _dashboard is null) return;
        try
        {
            var baseUrl = Endpoints.RealtimeBaseUrl;
            if (string.IsNullOrWhiteSpace(baseUrl))
                throw new InvalidOperationException("RealtimeBaseUrl is not set. Check wwwroot/appsettings.json.");

            await Hub.StartAsync(baseUrl);

            var widgetIds = Store.GetWidgetsToSubscribe(_dashboard);
            if (widgetIds.Count > 0)
                await Hub.JoinWidgetsAsync(widgetIds);
            else
            {
                var machineCodes = Store.GetMachinesToSubscribe(_dashboard);
                if (machineCodes.Count > 0)
                    await Hub.JoinMachinesAsync(machineCodes);
            }

            _hubStarted = true;
            _rtError = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _rtError = ex.GetType().Name;
            Console.Error.WriteLine(ex.ToString());
            StateHasChanged();
        }
    }

    private async Task Reconnect()
    {
        _hubStarted = false;
        _rtError = null;
        await InvokeAsync(StateHasChanged);
    }

    private void OnStoreChanged() => InvokeAsync(StateHasChanged);
    private void OnHubStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Hub.WidgetUpdated -= Store.OnWidgetUpdate;
        Hub.WidgetUpdated -= OnWidgetUpdated;
        Store.Changed -= OnStoreChanged;
        Hub.StateChanged -= OnHubStateChanged;
    }
}
