{
    // Connection strings used by the realtime gateway.  Adjust to point to
    // the same database used by the acquisition runtime so that catalog
    // endpoints return consistent data.
    "ConnectionStrings": {
        "DefaultConnection": "Server=.\\MSSQLSERVER01;Initial Catalog=OpcUaData;Integrated Security=True;TrustServerCertificate=True"
    },
    // Additional configuration for SignalR or logging can be placed here.
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    },
    "CycleTracking": {
        "Enabled": true,
        "RuleReloadSeconds": 30,
        "ScopeResolver": "Db311"
    }
}